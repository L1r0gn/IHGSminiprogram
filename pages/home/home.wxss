/* pages/home/home.wxss */
page {
  background-color: #f4f6f8;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
}

.page-container {
  position: relative;
  min-height: 100vh;
}

/* 关键：弧形背景 */
.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 400rpx;
  background: linear-gradient(135deg, #5b86e5 0%, #36d1dc 100%);
  border-bottom-left-radius: 80rpx;
  border-bottom-right-radius: 80rpx;
}

.content-wrapper {
  position: relative;
  padding: 40rpx;
  padding-top: 80rpx;
}

/* 用户信息 */
.user-profile {
  display: flex;
  align-items: center;
  margin-bottom: 60rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid #fff;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  margin-right: 30rpx;
}

.user-info {
  color: #fff;
}

.greeting {
  font-size: 44rpx;
  font-weight: 600;
  display: block;
}

.sub-greeting {
  font-size: 28rpx;
  opacity: 0.8;
}

/* 功能区 */
.action-section {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.06);
}

.section-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 40rpx;
}

.action-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 30rpx;
}

.action-card {
  display: flex;
  align-items: center;
  padding: 30rpx;
  background-color: #f8f9fa;
  border-radius: 20rpx;
  transition: transform 0.2s ease;
}

.action-card:active {
  transform: scale(0.96);
}

.icon-wrapper {
  flex-shrink: 0;
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.card-icon {
  width: 48rpx;
  height: 48rpx;
}

.card-content {
  display: flex;
  flex-direction: column;
}

.card-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 4rpx;
}

.card-desc {
  font-size: 24rpx;
  color: #999;
}