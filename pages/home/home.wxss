/* pages/home/home.wxss - 简约风格 */
page {
  background-color: #f5f7fa;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
}

.page-container {
  min-height: 100vh;
  background: #f5f7fa;
}

/* 顶部导航栏 */
.top-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 40rpx 40rpx 20rpx;
  background: #fff;
}

.nav-left {
  display: flex;
  align-items: center;
}

.login-text {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

.nav-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  border: 2rpx solid #e8e8e8;
}

.nav-right {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.more-btn {
  font-size: 40rpx;
  color: #666;
  font-weight: bold;
}

.scan-btn {
  font-size: 40rpx;
  color: #333;
}

/* 内容区域 */
.content-wrapper {
  padding: 0 40rpx 40rpx;
  background: #fff;
}

/* 欢迎语 */
.welcome-section {
  padding: 20rpx 0 40rpx;
  animation: fadeIn 0.6s ease-out;
}

.welcome-title {
  font-size: 52rpx;
  font-weight: 700;
  color: #1a1a1a;
  display: block;
  margin-bottom: 12rpx;
}

.welcome-subtitle {
  font-size: 28rpx;
  color: #999;
  display: block;
}

/* 搜索/拍照区域 */
.search-section {
  margin-bottom: 48rpx;
  animation: fadeInUp 0.6s ease-out 0.2s both;
}

.search-card {
  background: linear-gradient(135deg, #4A90E2 0%, #5BA3F5 100%);
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 8rpx 32rpx rgba(74, 144, 226, 0.3);
  transition: all 0.3s ease;
}

.search-card:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(74, 144, 226, 0.4);
}

.search-icon {
  width: 120rpx;
  height: 120rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

.icon-camera {
  font-size: 70rpx;
  transform: translateY(-13rpx);
}

.search-text {
  text-align: center;
}

.search-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #fff;
  display: block;
  margin-bottom: 12rpx;
}

.search-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  display: block;
}

/* 快捷功能 */
.quick-section {
  animation: fadeInUp 0.6s ease-out 0.4s both;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 32rpx;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

.quick-item {
  display: flex;
  align-items: center;
  padding: 32rpx 24rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s ease;
  border: 1rpx solid #f0f0f0;
}

.quick-item:active {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

.quick-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.icon-blue {
  background: linear-gradient(135deg, #E3F2FD 0%, #BBDEFB 100%);
}

.icon-orange {
  background: linear-gradient(135deg, #FFF3E0 0%, #FFE0B2 100%);
}

.icon-green {
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
}

.icon-purple {
  background: linear-gradient(135deg, #F3E5F5 0%, #E1BEE7 100%);
}

.icon-cyan {
  background: linear-gradient(135deg, #E0F7FA 0%, #B2EBF2 100%);
}

.icon-pink {
  background: linear-gradient(135deg, #FCE4EC 0%, #F8BBD9 100%);
}

.quick-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.quick-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 8rpx;
}

.quick-desc {
  font-size: 24rpx;
  color: #999;
}

/* 动画 */
@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
