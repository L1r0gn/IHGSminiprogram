/* pages/home/home.wxss */
page {
  background-color: #f8fafc;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
}

.page-container {
  position: relative;
  min-height: 100vh;
}

/* 弧形渐变背景 */
.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 480rpx;
  background: linear-gradient(135deg, #4f6cf9 0%, #2a9dfe 100%);
  border-bottom-left-radius: 100rpx;
  border-bottom-right-radius: 100rpx;
  z-index: 0;
}

.content-wrapper {
  position: relative;
  padding: 60rpx;
  padding-top: 120rpx;
  z-index: 2;
}

/* 用户信息区 */
.user-profile {
  display: flex;
  align-items: center;
  margin-bottom: 70rpx;
}

.avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 4rpx solid white;
  box-shadow: 0 12rpx 30rpx rgba(0, 0, 0, 0.15);
  margin-right: 36rpx;
  flex-shrink: 0;
}

.user-info {
  color: white;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.greeting {
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1.3;
  letter-spacing: -0.5rpx;
}

.sub-greeting {
  font-size: 28rpx;
  opacity: 0.9;
  margin-top: 8rpx;
}

/* 功能区容器 */
.action-section {
  background: white;
  border-radius: 28rpx;
  padding: 48rpx;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.08);
  backdrop-filter: blur(10rpx);
}

.section-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #1e293b;
  margin-bottom: 44rpx;
  text-align: left;
}

/* 功能卡片网格 */
.action-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300rpx, 1fr));
  gap: 32rpx;
}

.action-card {
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 36rpx;
  background: #f9fbfd;
  border-radius: 24rpx;
  transition: all 0.25s ease;
  border: 1rpx solid #edf2f7;
}

.action-card:active {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.1);
}

.card-content {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 8rpx;
}

.card-desc {
  font-size: 26rpx;
  color: #64748b;
  line-height: 1.4;
}