<view class="page-container">
  <!-- 顶部导航栏 -->
  <view class="top-nav">
    <view class="nav-left">
      <text class="login-text" wx:if="{{!isLoggedIn}}" bindtap="handleLogin">登录</text>
      <image 
        wx:else
        class="nav-avatar" 
        bindtap="handleAvatarTap" 
        src="{{userInfo.wx_avatar || defaultAvatarUrl}}" 
        mode="aspectFill"
      ></image>
    </view>
  </view>

  <view class="content-wrapper">
    <!-- 欢迎语 -->
    <view class="welcome-section">
      <text class="welcome-title">Hi，{{greeting}}！</text>
      <text class="welcome-subtitle">欢迎来到智能批改系统</text>
    </view>

    <!-- 搜索/拍照区域 -->
    <view class="search-section" bindtap="startPractice">
      <view class="search-card">
        <view class="search-icon">
          <text class="icon-camera">📷</text>
        </view>
        <view class="search-text">
          <text class="search-title">开始做题</text>
          <text class="search-desc">挑战今日题目</text>
        </view>
      </view>
    </view>

    <!-- 快捷功能 -->
    <view class="quick-section">
      <view class="section-title">快捷功能</view>
      <view class="quick-grid">
        <!-- <navigator url="/pages/student_mode/question/search/search" class="quick-item">
          <view class="quick-icon icon-blue">📝</view>
          <view class="quick-info">
            <text class="quick-name">开始做题</text>
            <text class="quick-desc">挑战今日题目</text>
          </view>
        </navigator> -->

        <navigator url="/pages/user/learningStats/learningStats" class="quick-item" wx:if="{{isStudent}}">
          <view class="quick-icon icon-orange">📊</view>
          <view class="quick-info">
            <text class="quick-name">学习数据</text>
            <text class="quick-desc">查看学习报告</text>
          </view>
        </navigator>

        <navigator url="/pages/student_mode/myclass/myclass" class="quick-item" wx:if="{{isStudent}}">
          <view class="quick-icon icon-green">📚</view>
          <view class="quick-info">
            <text class="quick-name">我的班级</text>
            <text class="quick-desc">管理班级事务</text>
          </view>
        </navigator>

        <navigator url="/pages/classFunction/classManage/classManage" class="quick-item" wx:if="{{isTeacher}}">
          <view class="quick-icon icon-purple">🏫</view>
          <view class="quick-info">
            <text class="quick-name">班级管理</text>
            <text class="quick-desc">创建管理班级</text>
          </view>
        </navigator>

        <navigator url="/pages/user/list/userList" class="quick-item">
          <view class="quick-icon icon-cyan">👤</view>
          <view class="quick-info">
            <text class="quick-name">信息管理</text>
            <text class="quick-desc">个人资料设置</text>
          </view>
        </navigator>

        <!-- <navigator url="/pages/student_mode/learningInsights/knowledgeProfile" class="quick-item" wx:if="{{isStudent}}">
          <view class="quick-icon icon-pink">🎯</view>
          <view class="quick-info">
            <text class="quick-name">知识画像</text>
            <text class="quick-desc">掌握程度分析</text>
          </view>
        </navigator> -->
      </view>
    </view>
  </view>
</view>
