/* pages/profile/profile.wxss - 简约风格 */
page {
  background-color: #f5f7fa;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
}

.page-container {
  min-height: 100vh;
  padding-bottom: 120rpx;
}

.content-wrapper {
  padding: 40rpx;
}

/* 用户卡片 */
.user-card {
  display: flex;
  align-items: center;
  padding: 48rpx;
  background: white;
  border-radius: 28rpx;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.1);
  margin-bottom: 32rpx;
  animation: fadeInDown 0.8s ease-out;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid #e2e8f0;
  margin-right: 32rpx;
  flex-shrink: 0;
  position: relative;
  overflow: hidden;
  transition: all 0.3s ease;
}

/* 头像编辑动画 */
.user-avatar::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(
    45deg,
    transparent 40%,
    rgba(74, 144, 226, 0.1) 50%,
    transparent 60%
  );
  transform: translateX(-100%);
  transition: transform 0.6s ease;
}

.user-avatar:active {
  transform: scale(1.1);
  box-shadow: 0 8rpx 20rpx rgba(74, 144, 226, 0.3);
}

.user-avatar:active::after {
  transform: translateX(100%);
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #1e293b;
  margin-bottom: 8rpx;
  display: block;
  animation: fadeIn 1s ease-out 0.2s both;
}

.user-role {
  font-size: 26rpx;
  color: #64748b;
  padding: 4rpx 16rpx;
  background: #f1f5f9;
  border-radius: 12rpx;
  display: inline-block;
  animation: fadeIn 1s ease-out 0.4s both;
  align-self: flex-start;
}

.edit-btn,
.login-btn {
  width: 250rpx !important;
  height: 64rpx;
  line-height: 64rpx;
  background: linear-gradient(135deg, #f3e7e9 0%, #e3eeff 100%);
  color: #4A90E2;
  border: none;
  border-radius: 32rpx;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(74, 144, 226, 0.2);
  transition: all 0.3s ease;
  margin-left: 16rpx;
  text-align: center;
  padding: 0;
  flex-shrink: 0;
}

.login-btn::after,
.edit-btn::after {
  border: none;
}

.login-btn:active,
.edit-btn:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 8rpx rgba(74, 144, 226, 0.3);
}

/* 统计卡片 */
.stats-card {
  display: flex;
  align-items: center;
  padding: 48rpx;
  background: white;
  border-radius: 28rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  margin-bottom: 40rpx;
  animation: fadeInUp 0.6s ease-out 0.2s both;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-value {
  font-size: 44rpx;
  font-weight: 700;
  color: #4A90E2;
  display: block;
  margin-bottom: 8rpx;
  animation: slideInUp 0.6s ease-out 0.4s both;
}

.stat-label {
  font-size: 24rpx;
  color: #64748b;
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background: #e2e8f0;
}

/* 菜单区域 */
.menu-section {
  margin-bottom: 32rpx;
  animation: fadeInUp 0.6s ease-out 0.4s both;
}

.menu-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1e293b;
  margin-bottom: 20rpx;
  padding-left: 12rpx;
}

.menu-list {
  background: white;
  border-radius: 28rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx 40rpx;
  border-bottom: 1rpx solid #f1f5f9;
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

/* 水波纹效果 */
.menu-item::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 0;
  height: 0;
  background: rgba(74, 144, 226, 0.1);
  border-radius: 50%;
  transform: translate(-50%, -50%);
  transition: width 0.6s ease, height 0.6s ease;
}

.menu-item:active::before {
  width: 600rpx;
  height: 600rpx;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: #f8fafc;
  transform: translateX(8rpx);
}

.menu-icon {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #f3e7e9 0%, #e3eeff 100%);
  border-radius: 12rpx;
  font-size: 28rpx;
  margin-right: 24rpx;
  transition: all 0.3s ease;
}

.menu-item:active .menu-icon {
  transform: scale(1.1) rotate(5deg);
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #1e293b;
  transition: color 0.3s ease;
}

.menu-item:active .menu-text {
  color: #4A90E2;
}

.menu-arrow {
  font-size: 32rpx;
  color: #cbd5e1;
  transition: transform 0.3s ease;
}

.menu-item:active .menu-arrow {
  transform: translateX(8rpx);
  color: #4A90E2;
}

.logout-item .menu-icon {
  background: #fee2e2;
}

.logout-item .menu-text {
  color: #dc2626;
}

.logout-item:active .menu-text {
  color: #b91c1c;
}
