/* pages/classFunction/classDetail/classDetail.wxss - 简约风格 */
page {
  background-color: #f5f7fa;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
}

.page-container {
  min-height: 100vh;
}

.content-wrapper {
  padding: 40rpx;
}

.page-header {
  margin-bottom: 40rpx;
  padding: 20rpx 0;
  animation: fadeIn 0.6s ease-out;
}

.page-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #1a1a1a;
  display: block;
  margin-bottom: 12rpx;
}

.page-subtitle {
  font-size: 28rpx;
  color: #999;
  display: block;
}

/* 基本信息卡片 */
.info-card {
  background: #fff;
  border-radius: 28rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  animation: fadeInUp 0.6s ease-out 0.2s both;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.info-item:last-child {
  margin-bottom: 0;
  align-items: flex-start;
}

.info-item:last-child .info-value {
  text-align: right;
  flex: 1;
  margin-left: 20rpx;
}

.info-label {
  font-size: 28rpx;
  color: #64748b;
  font-weight: 500;
  flex-shrink: 0;
}

.info-value {
  font-size: 28rpx;
  color: #1e293b;
  font-weight: 500;
  text-align: right;
  flex: 1;
}

/* 功能菜单 */
.menu-section {
  background: #fff;
  border-radius: 28rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  animation: fadeInUp 0.6s ease-out 0.3s both;
}

.menu-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1e293b;
  margin-bottom: 24rpx;
}

.menu-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
}

.menu-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 32rpx 24rpx;
  border-radius: 24rpx;
  background: #f8f9fa;
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
  margin-bottom: 50rpx;
}

.menu-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.05) 0%, rgba(118, 75, 162, 0.05) 100%);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.menu-item:active {
  transform: translateY(-4rpx) scale(1.05);
  box-shadow: 0 8rpx 20rpx rgba(102, 126, 234, 0.2);
}

.menu-item:active::before {
  opacity: 1;
}

.menu-icon {
  font-size: 56rpx;
  margin-bottom: 16rpx;
  transition: transform 0.3s ease;
}

.menu-item:active .menu-icon {
  transform: scale(1.1) rotate(5deg);
}

.menu-text {
  font-size: 28rpx;
  color: #1e293b;
  font-weight: 600;
  transition: color 0.3s ease;
}

.menu-item:active .menu-text {
  color: #667eea;
}

/* 创建作业区域 */
.create-section {
  margin-top: 32rpx;
  padding-top: 32rpx;
  border-top: 1rpx solid #e2e8f0;
}

.create-btn {
  width: 100%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 24rpx;
  padding: 32rpx;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.create-btn::after {
  border: none;
}

.create-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
  transition: left 0.5s ease;
}

.create-btn:active {
  transform: translateY(-4rpx) scale(0.98);
  box-shadow: 0 12rpx 32rpx rgba(102, 126, 234, 0.4);
}

.create-btn:active::before {
  left: 100%;
}

/* 作业区域 */
.homework-section {
  background: #fff;
  border-radius: 28rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  animation: fadeInUp 0.6s ease-out 0.4s both;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1e293b;
}

.section-more {
  font-size: 28rpx;
  color: #667eea;
  transition: all 0.3s ease;
}

.section-more:active {
  color: #764ba2;
  transform: translateX(4rpx);
}

.homework-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.homework-item {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  border-left: 6rpx solid #667eea;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.homework-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.05) 0%, rgba(118, 75, 162, 0.05) 100%);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.homework-item:active {
  transform: translateX(8rpx) translateY(-4rpx);
  box-shadow: 0 8rpx 20rpx rgba(102, 126, 234, 0.2);
}

.homework-item:active::before {
  opacity: 1;
}

.homework-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
  position: relative;
  z-index: 1;
}

.homework-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1e293b;
  flex: 1;
  margin-right: 20rpx;
  line-height: 1.4;
  transition: color 0.3s ease;
}

.homework-item:active .homework-title {
  color: #667eea;
}

.homework-status {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.homework-status.PENDING {
  background: #fef3c7;
  color: #d97706;
}

.homework-status.ACCEPTED {
  background: #d1fae5;
  color: #059669;
}

.homework-status.SUBMITTED {
  background: #d1fae5;
  color: #059669;
}

.homework-status.OVERDUE {
  background: #fee2e2;
  color: #dc2626;
}

.homework-status.WRONG_ANSWER {
  background: #fee2e2;
  color: #dc2626;
}

/* 教师视图：作业提交信息 */
.homework-meta-teacher {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.submit-count {
  font-size: 24rpx;
  color: #667eea;
  font-weight: 600;
  background: #e0e7ff;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  white-space: nowrap;
}

.homework-status-container {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.status-text {
  font-size: 24rpx;
}

.homework-desc {
  font-size: 26rpx;
  color: #64748b;
  line-height: 1.5;
  margin-bottom: 16rpx;
  display: block;
  position: relative;
  z-index: 1;
}

.homework-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  position: relative;
  z-index: 1;
}

.meta-item {
  font-size: 24rpx;
  color: #94a3b8;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
  background: white;
  border-radius: 28rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  animation: fadeInUp 0.6s ease-out 0.5s both;
}

.empty-icon {
  font-size: 120rpx;
  display: block;
  margin-bottom: 24rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 28rpx;
  color: #64748b;
  line-height: 1.6;
  display: block;
}

/* 操作按钮区域 */
.action-section {
  padding: 0 0 40rpx;
}

.action-btn {
  background: #fff;
  border: 2rpx solid #fee2e2;
  color: #dc2626;
  border-radius: 24rpx;
  padding: 28rpx;
  font-size: 28rpx;
  font-weight: 600;
  width: 100%;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s ease;
}

.action-btn::after {
  border: none;
}

.action-btn:active {
  background: #fee2e2;
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.action-btn.quit-btn {
  background: #fff;
  border: 2rpx solid #fee2e2;
  color: #dc2626;
}

.action-btn.quit-btn:active {
  background: #fee2e2;
}

.action-btn.delete-btn {
  background: linear-gradient(135deg, #f5576c 0%, #f093fb 100%);
  border: none;
  color: white;
  box-shadow: 0 8rpx 20rpx rgba(245, 87, 108, 0.3);
}

.action-btn.delete-btn:active {
  box-shadow: 0 4rpx 12rpx rgba(245, 87, 108, 0.4);
}

/* 弹窗样式 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
  padding: 40rpx;
  box-sizing: border-box;
}

.modal-container {
  background: white;
  border-radius: 28rpx;
  width: 100%;
  max-width: 600rpx;
  overflow: hidden;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.2);
  animation: modalSlideIn 0.3s ease-out;
}

@keyframes modalSlideIn {
  from {
    opacity: 0;
    transform: translateY(-50rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #e2e8f0;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.modal-body {
  padding: 32rpx;
}

.confirm-text {
  font-size: 30rpx;
  color: #1e293b;
  display: block;
  margin-bottom: 16rpx;
  text-align: center;
  font-weight: 600;
}

.confirm-tip {
  font-size: 26rpx;
  color: #94a3b8;
  display: block;
  text-align: center;
  line-height: 1.5;
}

.confirm-tip.warning {
  color: #dc2626;
  font-weight: 500;
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% {
    opacity: 1;
  }
  50% {
    opacity: 0.7;
  }
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 0 32rpx 32rpx;
}

.modal-btn {
  flex: 1;
  border: none;
  border-radius: 16rpx;
  padding: 24rpx 0;
  font-size: 28rpx;
  font-weight: 600;
  transition: all 0.3s ease;
  height: 88rpx;
  line-height: 40rpx;
}

.modal-btn::after {
  border: none;
}

.modal-btn.cancel {
  background: #f5f7fa;
  color: #64748b;
}

.modal-btn.cancel:active {
  background: #e2e8f0;
  transform: scale(0.98);
}

.modal-btn.confirm.quit {
  background: linear-gradient(135deg, #f5576c 0%, #f093fb 100%);
  color: white;
  box-shadow: 0 8rpx 20rpx rgba(245, 87, 108, 0.3);
}

.modal-btn.confirm.quit:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 12rpx rgba(245, 87, 108, 0.4);
}

.modal-btn.confirm.delete {
  background: linear-gradient(135deg, #f5576c 0%, #f093fb 100%);
  color: white;
  box-shadow: 0 8rpx 20rpx rgba(245, 87, 108, 0.3);
}

.modal-btn.confirm.delete:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 12rpx rgba(245, 87, 108, 0.4);
}

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 60rpx;
  background: white;
  border-radius: 28rpx;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.08);
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid #e2e8f0;
  border-top-color: #667eea;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 28rpx;
  color: #64748b;
}

/* 布置作业按钮 */
.create-homework-wrapper {
  padding: 0 20rpx;
  margin-bottom: 24rpx;
}

.create-homework-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  width: 100%;
  padding: 28rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 20rpx;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.35);
  transition: all 0.3s ease;
}

.create-homework-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.25);
}

.create-icon {
  font-size: 36rpx;
  font-weight: bold;
}

.section-actions {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

/* 空状态 */
.empty-homework {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 60rpx 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #94a3b8;
}

/* 基础动画 */
@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}