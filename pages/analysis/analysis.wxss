/* pages/analysis/analysis.wxss - 简约风格 */
page {
  background-color: #f5f7fa;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
}

.page-container {
  min-height: 100vh;
}

.content-wrapper {
  padding: 40rpx;
}

.page-header {
  margin-bottom: 40rpx;
  padding: 20rpx 0;
  animation: fadeIn 0.6s ease-out;
}

.page-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #1a1a1a;
  display: block;
  margin-bottom: 12rpx;
}

.page-subtitle {
  font-size: 28rpx;
  color: #999;
  display: block;
}

/* Tab切换 */
.tab-container {
  display: flex;
  background: white;
  border-radius: 20rpx;
  padding: 8rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  animation: fadeInUp 0.6s ease-out 0.2s both;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 16rpx;
  transition: all 0.3s ease;
}

.tab-item.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  transform: translateY(-4rpx);
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

.tab-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #64748b;
  transition: color 0.3s ease;
}

.tab-item.active .tab-text {
  color: white;
}

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 60rpx;
  background: white;
  border-radius: 28rpx;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.08);
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid #e2e8f0;
  border-top-color: #667eea;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 28rpx;
  color: #64748b;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 60rpx;
  background: white;
  border-radius: 28rpx;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.08);
  animation: fadeIn 0.8s ease-out 0.3s both;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
  animation: breathe 2s ease-in-out infinite;
}

.empty-text {
  font-size: 32rpx;
  color: #64748b;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: #94a3b8;
  margin-bottom: 40rpx;
}

.start-btn {
  width: 300rpx;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 20rpx rgba(102, 126, 234, 0.3);
  transition: all 0.3s ease;
}

.start-btn::after {
  border: none;
}

.start-btn:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.4);
}

/* 分析内容 */
.analysis-content {
  display: flex;
  flex-direction: column;
  animation: fadeInUp 0.6s ease-out 0.4s both;
}

/* Tab 内容容器 */
.tab-content {
  width: 100%;
}

/* 从右侧滑入动画 */
.tab-content.slide-in {
  animation: slideInRight 0.3s ease-out;
}

/* 向左滑出动画 */
.tab-content.slide-out-right {
  animation: slideOutLeft 0.3s ease-out;
}

/* 滑入动画 */
@keyframes slideInRight {
  from {
    transform: translateX(100%);
    opacity: 0;
  }
  to {
    transform: translateX(0);
    opacity: 1;
  }
}

/* 滑出动画 */
@keyframes slideOutLeft {
  from {
    transform: translateX(0);
    opacity: 1;
  }
  to {
    transform: translateX(-100%);
    opacity: 0;
  }
}

/* 概览卡片 */
.overview-cards {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24rpx;
  margin-bottom: 40rpx;
}

.overview-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 24rpx;
  padding: 40rpx 24rpx;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
  transition: all 0.3s ease;
  overflow: hidden;
}

.overview-card:nth-child(1) {
  animation: fadeInUp 0.5s ease-out 0.6s both;
}

.overview-card:nth-child(2) {
  animation: fadeInUp 0.5s ease-out 0.7s both;
}

.overview-card:nth-child(3) {
  animation: fadeInUp 0.5s ease-out 0.8s both;
}

.overview-card:active {
  transform: translateY(-4rpx) scale(1.05);
  box-shadow: 0 16rpx 40rpx rgba(102, 126, 234, 0.4);
}

.card-value {
  font-size: 48rpx;
  font-weight: 700;
  color: white;
  display: block;
  margin-bottom: 12rpx;
  animation: fadeIn 0.8s ease-out 0.6s both;
}

.card-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  display: block;
}

/* 做题记录概览 */
.record-overview {
  display: flex;
  gap: 24rpx;
  margin-bottom: 40rpx;
}

.record-card {
  flex: 1;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 24rpx;
  padding: 40rpx 24rpx;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
  transition: all 0.3s ease;
}

.record-card:active {
  transform: translateY(-4rpx) scale(1.05);
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
}

.record-card.secondary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  box-shadow: 0 8rpx 24rpx rgba(79, 172, 254, 0.3);
}

.record-value {
  font-size: 48rpx;
  font-weight: 700;
  color: white;
  display: block;
  margin-bottom: 12rpx;
  animation: fadeIn 0.8s ease-out 0.6s both;
}

.record-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  display: block;
}

/* 章节标题 */
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
  animation: fadeIn 0.6s ease-out 0.5s both;
}

.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1e293b;
}

.more-btn {
  font-size: 28rpx;
  color: #667eea;
  transition: all 0.3s ease;
}

.more-btn:active {
  color: #764ba2;
  transform: translateX(4rpx);
}

/* 知识点列表 */
.knowledge-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.knowledge-item {
  background: white;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
  overflow: hidden;
}

.knowledge-item:nth-child(1) {
  animation: fadeInUp 0.5s ease-out 0.6s both;
}

.knowledge-item:nth-child(2) {
  animation: fadeInUp 0.5s ease-out 0.7s both;
}

.knowledge-item:nth-child(3) {
  animation: fadeInUp 0.5s ease-out 0.8s both;
}

.knowledge-item:nth-child(4) {
  animation: fadeInUp 0.5s ease-out 0.9s both;
}

.knowledge-item:nth-child(5) {
  animation: fadeInUp 0.5s ease-out 1.0s both;
}

.knowledge-item:nth-child(6) {
  animation: fadeInUp 0.5s ease-out 1.1s both;
}

.knowledge-item:active {
  transform: translateY(-4rpx);
  box-shadow: 0 16rpx 40rpx rgba(0, 0, 0, 0.12);
}

.knowledge-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.knowledge-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1e293b;
  flex: 1;
  transition: color 0.3s ease;
}

.knowledge-item:active .knowledge-name {
  color: #667eea;
}

.mastery-badge {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 600;
  transition: all 0.3s ease;
}

.knowledge-item:active .mastery-badge {
  transform: scale(1.1);
}

.mastery-high {
  background: #d1fae5;
  color: #059669;
}

.mastery-medium {
  background: #fef3c7;
  color: #d97706;
}

.mastery-low {
  background: #fee2e2;
  color: #dc2626;
}

.knowledge-progress {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.progress-bar-bg {
  flex: 1;
  height: 12rpx;
  background: #e2e8f0;
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-bar-fill {
  height: 100%;
  border-radius: 6rpx;
  transition: width 0.6s ease-out;
}

.progress-bar-fill.mastery-high {
  background: linear-gradient(90deg, #34d399, #10b981);
}

.progress-bar-fill.mastery-medium {
  background: linear-gradient(90deg, #fbbf24, #f59e0b);
}

.progress-bar-fill.mastery-low {
  background: linear-gradient(90deg, #f87171, #ef4444);
}

.knowledge-meta {
  font-size: 24rpx;
  color: #64748b;
  flex-shrink: 0;
}

/* 做题记录列表 */
.record-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.record-item {
  background: white;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
}

.record-item:nth-child(1) {
  animation: fadeInUp 0.5s ease-out 1.4s both;
}

.record-item:nth-child(2) {
  animation: fadeInUp 0.5s ease-out 1.5s both;
}

.record-item:nth-child(3) {
  animation: fadeInUp 0.5s ease-out 1.6s both;
}

.record-item:nth-child(4) {
  animation: fadeInUp 0.5s ease-out 1.7s both;
}

.record-item:nth-child(5) {
  animation: fadeInUp 0.5s ease-out 1.8s both;
}

.record-item:active {
  transform: translateY(-4rpx);
  box-shadow: 0 16rpx 40rpx rgba(0, 0, 0, 0.12);
}

.record-date {
  font-size: 28rpx;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 20rpx;
  display: block;
}

.record-stats {
  display: flex;
  gap: 60rpx;
}

.record-stat {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #64748b;
}

.stat-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #667eea;
  transition: color 0.3s ease;
}

.record-item:active .stat-value {
  color: #764ba2;
}

/* 提交记录列表 */
.submission-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.submission-item {
  background: white;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
  overflow: hidden;
}

.submission-item:nth-child(1) {
  animation: fadeInUp 0.5s ease-out 0.6s both;
}

.submission-item:nth-child(2) {
  animation: fadeInUp 0.5s ease-out 0.7s both;
}

.submission-item:nth-child(3) {
  animation: fadeInUp 0.5s ease-out 0.8s both;
}

.submission-item:nth-child(4) {
  animation: fadeInUp 0.5s ease-out 0.9s both;
}

.submission-item:nth-child(5) {
  animation: fadeInUp 0.5s ease-out 1.0s both;
}

.submission-item:active {
  transform: translateY(-4rpx);
  box-shadow: 0 16rpx 40rpx rgba(0, 0, 0, 0.12);
}

.submission-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.submission-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1e293b;
  flex: 1;
  transition: color 0.3s ease;
}

.submission-item:active .submission-title {
  color: #667eea;
}

.submission-status {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 600;
  transition: all 0.3s ease;
}

.submission-item:active .submission-status {
  transform: scale(1.1);
}

.submission-status.status-correct {
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(16, 185, 129, 0.25);
}

.submission-status.status-partial {
  background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(245, 158, 11, 0.25);
}

.submission-status.status-wrong {
  background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(239, 68, 68, 0.25);
}

.submission-status.status-pending {
  background: #f3f4f6;
  color: #6b7280;
}

.submission-meta {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.submission-time {
  font-size: 24rpx;
  color: #64748b;
  flex-shrink: 0;
}

.submission-score {
  font-size: 32rpx;
  font-weight: 700;
  color: #6366f1;
  transition: color 0.3s ease;
}

.submission-item:active .submission-score {
  color: #667eea;
}

.load-more {
  text-align: center;
  padding: 40rpx 0;
  color: #94a3b8;
  font-size: 28rpx;
}

.empty-list {
  text-align: center;
  padding: 60rpx;
  background: white;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  animation: fadeIn 0.6s ease-out 0.6s both;
}

.empty-list-text {
  font-size: 28rpx;
  color: #64748b;
}
