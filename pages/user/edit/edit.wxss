/* 页面容器 */
.page-container {
  display: flex;
  flex-direction: column;
  padding: 20rpx;
  background-color: #f7f8fa;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 头像与昵称 */
.user-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  background-color: #ffffff;
  padding: 32rpx;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 16rpx rgba(0,0,0,0.05);
  /* 移除固定高度，让内容自适应 */
}

/* 修复头像按钮容器 */
.avatar-btn {
  width: 140rpx;
  height: 140rpx;
  padding: 0;
  margin: 0;
  border: none;
  background: transparent;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 0;
  font-size: 0;
  outline: none;
  -webkit-tap-highlight-color: transparent;
  /* 添加相对定位 */
  position: relative;
  overflow: hidden;
}

/* 修复头像图片样式 */
.avatar {
  width: 140rpx;  
  height: 140rpx; 
  border-radius: 50%;
  border: 6rpx solid #fff;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
  position: relative;
  z-index: 1;
  object-fit: cover;
}


.user-name {
  flex-grow: 1;
}

.nickname-input {
  width: 100%;
  padding: 16rpx 0;
font-size: 36rpx;
  font-weight: 500;
  color: #303133;
  border: none;
  background-color: transparent;
}
.nickname-input:focus {
  border-color: #4CAF50;
}
/* 信息卡片 */
.info-card {
  background-color: #fff;
  padding: 0 32rpx;
  margin-bottom: 24rpx;
  border-radius: 24rpx;
box-shadow: 0 8rpx 16rpx rgba(0,0,0,0.05);
}

.card-title {
  font-size: 34rpx;
  font-weight: 500;
  color: #303133;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #f2f3f5;
}

.info-list {
  display: flex;
  flex-direction: column;
}

/* 信息项 */
.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #f2f3f5;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 30rpx;
  color: #606266;
}

.info-value {
  font-size: 30rpx;
  color: #303133;
  text-align: right;
  flex: 1;
}

.info-input {
  width: 32%;
  padding: 10px;
  font-size: 16px;
  border: 1px solid #ccc;
  border-radius: 8px;
  background-color: #fff;
  color: #333;
  text-align: left;
}

.picker-container .info-value {
  font-size: 14px;
  color: #333;
}

/* 保存按钮 */
.save-btn-container {
  display: flex;
  justify-content: center;
  margin-top: 30px;
}
.save-btn {
  width: 90%;
  padding: 24rpx;
  font-size: 32rpx;
  font-weight: 500;
  background: linear-gradient(135deg, #07c160, #19be6b);
  color: white;
  border: none;
  border-radius: 48rpx;
  cursor: pointer;
box-shadow: 0 8rpx 16rpx rgba(0, 191, 99, 0.2);
  transition: all 0.3s ease;
}
.save-btn:hover {
  background-color: #45a049;
}