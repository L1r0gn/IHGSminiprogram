<view class="page-container">
  <!-- 编辑页面的头部 -->
  <view class="user-header">
    <image 
      class="avatar" 
      src="{{userInfo.avatarUrl || 'https://mmbiz.qpic.cn/mmbiz/icTdbqWNOwNRna42FI242Lcia07jQodd2FJGIYQfG0LAJGFxM4FbnQP6yfMxBgJ0F3YRqJCJ1aPAK2dQagdusBZg/0'}}"
      mode="aspectFill"
      bindtap="chooseAvatar"
    ></image>
    <view class="user-name">
      <input 
        class="nickname-input" 
        type="text" 
        value="{{userInfo.nickName}}" 
        placeholder="请输入昵称" 
        bindinput="onNicknameInput"
      />
    </view>
  </view>

  <!-- 基本信息编辑 -->
  <view class="info-card">
    <view class="card-title">基本信息</view>
    <view class="info-list">

      <!-- 性别 -->
      <view class="info-item">
        <view class="info-label">性别</view>
        <picker 
          mode="selector" 
          range="{{genderOptions}}" 
          value="{{genderIndex}}" 
          bindchange="onGenderChange"
        >
          <view class="info-value">{{genderOptions[genderIndex] || '未设置'}}</view>
        </picker>
      </view>
      
      <!-- 用户属性（学生/教师） -->
      <view class="info-item">
        <view class="info-label">身份</view>
        <picker 
          mode="selector" 
          range="{{userAttributeOptions}}" 
          value="{{userAttributeIndex}}" 
          bindchange="onUserAttributeChange"
        >
          <view class="info-value">{{userAttributeOptions[userAttributeIndex] || '未设置'}}</view>
        </picker>
      </view>

      <!-- 手机号 -->
      <view class="info-item">
        <view class="info-label">手机号</view>
        <input 
          class="info-input" 
          type="text" 
          value="{{userInfo.phone}}" 
          placeholder="请输入手机号" 
          bindinput="onPhoneInput"
        />
      </view>
      
      <!-- 所属班级 -->
      <view class="info-item">
        <view class="info-label">所属班级</view>
        <picker 
          mode="selector" 
          range="{{classList}}" 
          range-key="name"  
          value="{{classIndex}}" 
          bindchange="onClassChange"
        >
          <view class="info-value">
            {{userInfo.class_in && userInfo.class_in.name || '请选择班级'}}
          </view>
        </picker>
      </view>
    </view>
  </view>

  <!-- 微信关联信息编辑 -->
  <view class="info-card">
    <view class="card-title">微信关联信息</view>
    <view class="info-list">
      <!-- 最后登录时间 -->
      <view class="info-item">
        <view class="info-label">最后登录</view>
        <view class="info-value">{{userInfo.last_login_time ? formatTime(userInfo.last_login_time) : '未记录'}}</view>
      </view>
    </view>
  </view>

  <!-- 保存按钮 -->
  <view class="save-btn-container">
    <button class="save-btn" bindtap="saveToServer">保存修改</button>
  </view>
</view>
