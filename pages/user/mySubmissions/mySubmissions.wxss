/* pages/record/record.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #f5f7fa 0%, #e4edf5 100%);
  padding: 20rpx 0; /* 去掉左右padding，让内容更宽 */
}

.header {
  text-align: center;
  padding: 40rpx 30rpx; /* 增加左右padding */
  margin-bottom: 20rpx;
  background: rgba(255, 255, 255, 0.9);
  margin: 20rpx 20rpx 30rpx 20rpx; /* 左右留一些边距 */
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.title {
  font-size: 38rpx; /* 稍微增大标题 */
  font-weight: 700; /* 加粗 */
  color: #2c3e50;
  position: relative;
  display: inline-block;
}

.title::after {
  content: '';
  position: absolute;
  bottom: -12rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 100rpx; /* 加长下划线 */
  height: 6rpx;
  background: linear-gradient(to right, #3498db, #2ecc71);
  border-radius: 3rpx;
}

.sub-title {
  display: block;
  margin-top: 16rpx;
  font-size: 28rpx;
  color: #7f8c8d;
  font-weight: 500;
}

.record-list {
  width: 80%;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding: 0 20rpx; /* 列表容器左右padding */
}

.record-item {
  background: #ffffff;
  border-radius: 20rpx; /* 增大圆角 */
  padding: 36rpx 32rpx; /* 增加内边距 */
  box-shadow: 0 6rpx 25rpx rgba(0, 0, 0, 0.08); /* 增强阴影 */
  border-left: 10rpx solid #3498db; /* 加粗左侧边框 */
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
  margin: 0 0rpx; /* 去掉左右margin，让卡片更宽 */
  width: auto; /* 自动宽度，撑满容器 */
}

.record-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 6rpx; /* 加粗顶部线条 */
  background: linear-gradient(to right, #3498db, #2ecc71);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.record-item:active {
  transform: translateY(4rpx);
  box-shadow: 0 3rpx 15rpx rgba(0, 0, 0, 0.1);
}

.record-item:active::before {
  opacity: 1;
}

.problem-title {
  font-size: 34rpx; /* 增大字体 */
  font-weight: 700; /* 加粗 */
  color: #2c3e50;
  margin-bottom: 24rpx; /* 增加下边距 */
  display: flex;
  align-items: center;
  padding-right: 20rpx; /* 右侧留白 */
}

.problem-title::before {
  content: '📝';
  margin-right: 16rpx; /* 增加图标间距 */
  font-size: 32rpx; /* 增大图标 */
}

.meta {
  display: flex;
  align-items: center;
  margin-bottom: 28rpx; /* 增加下边距 */
  flex-wrap: wrap;
  gap: 20rpx; /* 增加元素间距 */
  justify-content: space-between; /* 左右对齐 */
  padding-right: 20rpx; /* 右侧留白 */
}

.time {
  font-size: 28rpx; /* 增大字体 */
  color: #7f8c8d;
  display: flex;
  align-items: center;
  flex: 1; /* 占据剩余空间 */
  min-width: 300rpx; /* 最小宽度 */
}

.time::before {
  content: '🕒';
  margin-right: 12rpx; /* 增加图标间距 */
  font-size: 26rpx; /* 增大图标 */
}

.status {
  padding: 12rpx 24rpx; /* 增大内边距 */
  border-radius: 25rpx; /* 增大圆角 */
  font-size: 26rpx; /* 增大字体 */
  font-weight: 600; /* 加粗 */
  min-width: 120rpx; /* 最小宽度 */
  text-align: center;
  white-space: nowrap; /* 不换行 */
}

.status.correct {
  background: rgba(46, 204, 113, 0.15);
  color: #27ae60;
  border: 2rpx solid rgba(46, 204, 113, 0.4);
}

.status.incorrect {
  background: rgba(231, 76, 60, 0.15);
  color: #c0392b;
  border: 2rpx solid rgba(231, 76, 60, 0.4);
}

.status.pending {
  background: rgba(241, 196, 15, 0.15);
  color: #f39c12;
  border: 2rpx solid rgba(241, 196, 15, 0.4);
}

.score-section {
  margin-bottom: 32rpx; /* 增加下边距 */
  padding-right: 20rpx; /* 右侧留白 */
}

.score {
  font-size: 30rpx; /* 增大字体 */
  font-weight: 700; /* 加粗 */
  color: #e74c3c;
  display: flex;
  align-items: center;
}

.score::before {
  content: '⭐';
  margin-right: 12rpx; /* 增加图标间距 */
  font-size: 28rpx; /* 增大图标 */
}

.no-score {
  font-size: 28rpx; /* 增大字体 */
  color: #95a5a6;
  display: flex;
  align-items: center;
}

.no-score::before {
  content: '⏳';
  margin-right: 12rpx; /* 增加图标间距 */
  font-size: 26rpx; /* 增大图标 */
}

.detail-btn {
  background: linear-gradient(135deg, #3498db, #2980b9);
  color: white;
  border: none;
  border-radius: 16rpx;
  padding: 20rpx 40rpx; 
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 6rpx 18rpx rgba(52, 152, 219, 0.4); 
  transition: all 0.3s ease;
  margin-top: 10rpx;
  width: 200rpx; 
}

.detail-btn:active {
  transform: translateY(3rpx);
  box-shadow: 0 3rpx 9rpx rgba(52, 152, 219, 0.4);
}

.empty {
  text-align: center;
  padding: 120rpx 40rpx; /* 增加内边距 */
  color: #95a5a6;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 20rpx;
  margin: 40rpx 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.empty-icon {
  font-size: 100rpx; /* 增大图标 */
  display: block;
  margin-bottom: 30rpx; /* 增加下边距 */
  opacity: 0.5;
}

.empty-text {
  font-size: 32rpx; /* 增大字体 */
  color: #95a5a6;
  display: block;
  margin-bottom: 16rpx; /* 增加下边距 */
  font-weight: 600; /* 加粗 */
}

.empty-tip {
  font-size: 26rpx; /* 增大字体 */
  color: #bdc3c7;
}

/* 加载动画 */
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.record-item {
  animation: fadeInUp 0.5s ease forwards;
}

/* 为不同状态设置不同的左侧边框颜色 */
.record-item.correct {
  border-left-color: #27ae60;
}

.record-item.incorrect {
  border-left-color: #e74c3c;
}

.record-item.pending {
  border-left-color: #f39c12;
}

/* 响应式调整 */
@media (max-width: 375px) {
  .record-list {
    padding: 0 15rpx;
  }
  
  .record-item {
    margin: 0 0rpx;
    padding: 32rpx 28rpx;
  }
  
  .meta {
    flex-direction: column;
    align-items: flex-start;
    gap: 16rpx;
  }
  
  .time {
    min-width: auto;
  }
}