page {
  background: #fafbfc;
  min-height: 100vh;
}

/* 页面容器 */
.page-container {
  min-height: 100vh;
}

.content-wrapper {
  padding: 16px;
}

/* 页面头部 */
.page-header {
  padding: 12px 0;
  margin-bottom: 12px;
}

.page-title {
  display: block;
  font-size: 22px;
  font-weight: 700;
  color: #1e293b;
}

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60px 20px;
}

.loading-spinner {
  width: 40px;
  height: 40px;
  border: 3px solid #e2e8f0;
  border-top-color: #667eea;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 16px;
  font-size: 14px;
  color: #64748b;
}

/* 记录概览 */
.record-overview {
  display: flex;
  gap: 10px;
  margin-bottom: 20px;
  animation: fadeIn 0.6s ease-out 0.5s both;
}

.record-card {
  flex: 1;
  background: white;
  border-radius: 12px;
  padding: 14px 12px;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 2px 8px rgba(102, 126, 234, 0.08);
  animation: fadeInUp 0.5s ease-out both;
}

.record-card.primary {
  animation-delay: 0.6s;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.record-card.secondary {
  animation-delay: 0.7s;
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
}

.record-card.primary .record-value,
.record-card.primary .record-label {
  color: white;
}

.record-card.secondary .record-value,
.record-card.secondary .record-label {
  color: white;
}

.record-value {
  font-size: 24px;
  font-weight: 700;
  margin-bottom: 6px;
}

.record-label {
  font-size: 11px;
  opacity: 0.9;
}

/* 章节标题 */
.section-header {
  margin-bottom: 12px;
  animation: fadeIn 0.6s ease-out 0.5s both;
}

.section-title {
  font-size: 15px;
  font-weight: 600;
  color: #1e293b;
}

/* 提交记录列表 */
.submission-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.submission-item {
  background: white;
  border-radius: 12px;
  padding: 16px;
  box-shadow: 0 2px 8px rgba(102, 126, 234, 0.08);
  transition: all 0.3s ease;
  overflow: hidden;
}

.submission-item:nth-child(1) {
  animation: fadeInUp 0.5s ease-out 0.6s both;
}

.submission-item:nth-child(2) {
  animation: fadeInUp 0.5s ease-out 0.7s both;
}

.submission-item:nth-child(3) {
  animation: fadeInUp 0.5s ease-out 0.8s both;
}

.submission-item:nth-child(4) {
  animation: fadeInUp 0.5s ease-out 0.9s both;
}

.submission-item:nth-child(5) {
  animation: fadeInUp 0.5s ease-out 1.0s both;
}

.submission-item:active {
  transform: translateY(-2px);
  box-shadow: 0 4px 12px rgba(102, 126, 234, 0.12);
}

.submission-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12px;
}

.submission-title {
  font-size: 15px;
  font-weight: 600;
  color: #1e293b;
  flex: 1;
  transition: color 0.3s ease;
}

.submission-item:active .submission-title {
  color: #667eea;
}

.submission-status {
  padding: 4px 12px;
  border-radius: 12px;
  font-size: 12px;
  font-weight: 600;
  transition: all 0.3s ease;
}

.submission-item:active .submission-status {
  transform: scale(1.1);
}

.submission-status.status-correct {
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  color: #fff;
  box-shadow: 0 2px 6px rgba(16, 185, 129, 0.25);
}

.submission-status.status-partial {
  background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
  color: #fff;
  box-shadow: 0 2px 6px rgba(245, 158, 11, 0.25);
}

.submission-status.status-wrong {
  background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
  color: #fff;
  box-shadow: 0 2px 6px rgba(239, 68, 68, 0.25);
}

.submission-status.status-pending {
  background: #f3f4f6;
  color: #6b7280;
}

.submission-meta {
  display: flex;
  align-items: center;
  gap: 12px;
}

.submission-time {
  font-size: 12px;
  color: #64748b;
  flex-shrink: 0;
}

.submission-score {
  font-size: 14px;
  font-weight: 700;
  color: #6366f1;
  transition: color 0.3s ease;
}

.submission-item:active .submission-score {
  color: #667eea;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 20px;
  color: #94a3b8;
  font-size: 13px;
}

/* 空状态 */
.empty-list {
  text-align: center;
  padding: 60px 20px;
  color: #94a3b8;
  font-size: 14px;
}

/* 动画 */
@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
