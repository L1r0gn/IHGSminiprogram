<view class="page-container">
  <view class="user-header">
    <view class="header-bg"></view>
    <image 
      class="avatar" 
      src="{{userInfo.avatarUrl || 'https://mmbiz.qpic.cn/mmbiz/icTdbqWNOwNRna42FI242Lcia07jQodd2FJGIYQfG0LAJGFxM4FbnQP6yfMxBgJ0F3YRqJCJ1aPAK2dQagdusBZg/0'}}"
      mode="widthFix"
    ></image>
    <view class="user-name">{{userInfo.nickName ||
'未设置昵称'}}</view>
    <navigator url="/pages/user/edit/edit" class="edit-btn">
      <text>编辑资料</text>
    </navigator>
  </view>

  <view class="info-card">
    <view class="card-title">基本信息</view>
    <view class="info-list">
      <view class="info-item">
        <view class="info-label">手机号</view>
        <view class="info-value">{{userInfo.phone ||
'未绑定'}}</view>
      </view>
      
      <view class="info-item">
        <view class="info-label">性别</view>
        <view class="info-value">
          <block wx:if="{{userInfo.gender === 1}}">男</block>
          <block wx:elif="{{userInfo.gender === 2}}">女</block>
          <block wx:else>未设置</block>
        </view>
      </view>
    
  
      <view class="info-item">
        <view class="info-label">身份</view>
        <view class="info-value">
          <block wx:if="{{userInfo.user_attribute === 1}}">学生</block>
          <block wx:elif="{{userInfo.user_attribute === 2}}">教师</block>
          <block wx:else>未设置</block>
        </view>
      </view>
      
      <view class="info-item">
        <view class="info-label">所属班级</view>
        <view class="info-value">
          {{userInfo.class_in && userInfo.class_in.name ?
userInfo.class_in.name : '未关联班级'}}
        </view>
      </view>
    </view>
  </view>

  <view class="info-card">
    <view class="card-title">微信关联信息</view>
    <view class="info-list">
      <view class="info-item">
        <view class="info-label">地区</view>
        <view class="info-value">
          {{userInfo.wx_country ||
''}}{{userInfo.wx_province ? '·' + userInfo.wx_province : ''}}{{userInfo.wx_city ? '·' + userInfo.wx_city : ''}}
          <block wx:if="{{!userInfo.wx_country && !userInfo.wx_province && !userInfo.wx_city}}">未获取</block>
        </view>
      </view>
      
      <view class="info-item">
        <view class="info-label">最后登录</view>
        <view class="info-value">{{userInfo.last_login_time ?
formatTime(userInfo.last_login_time) : '未记录'}}</view>
      </view>
    </view>
  </view>
</view>