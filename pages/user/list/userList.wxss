/* pages/user/mine/mine.wxss */
.page-container {
  background-color: #f7f8fa;
  min-height: 100vh;
  padding: 20rpx;
  box-sizing: border-box;
}

/* 顶部头像区域 */
.user-header {
  position: relative;
  display: flex;
  flex-direction: column;
align-items: center;
  padding: 60rpx 40rpx;
  background-color: #ffffff;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 16rpx rgba(0,0,0,0.05);
  overflow: hidden;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 200rpx;
  background: linear-gradient(135deg, #07c160, #19be6b);
  border-radius: 0 0 50% 50% / 0 0 100% 100%;
  transform: scaleX(1.5);
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 6rpx solid #fff;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
margin-bottom: 20rpx;
  position: relative;
  z-index: 1;
}

.user-name {
  font-size: 40rpx;
  font-weight: 500;
  color: #303133;
  margin-bottom: 30rpx;
  position: relative;
  z-index: 1;
}

.edit-btn {
  background-color: #07c160;
color: #fff;
  padding: 14rpx 40rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  transition: all 0.3s ease;
  position: relative;
  z-index: 1;
}

.edit-btn:active {
  transform: scale(0.95);
  opacity: 0.9;
}

/* 信息卡片样式 */
.info-card {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 0 32rpx;
margin-bottom: 24rpx;
  box-shadow: 0 8rpx 16rpx rgba(0,0,0,0.05);
}

.card-title {
  font-size: 34rpx;
  font-weight: 500;
  color: #303133;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #f2f3f5;
}

/* 信息列表样式 */
.info-list {
  display: flex;
  flex-direction: column;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 30rpx;
padding: 28rpx 0;
  border-bottom: 1rpx solid #f2f3f5;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  color: #606266;
}

.info-value {
  color: #303133;
  text-align: right;
word-break: break-all;
}