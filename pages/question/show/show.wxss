/* pages/question/show/show.wxss */

/* 题目样式 */
.question-container {
  padding: 20px;
  background: #f9f9f9;
  border-radius: 8px;
  margin-bottom: 20px;
}
.question-text {
  font-size: 18px;
  font-weight: bold;
}

/* 选项样式 */
.option-item {
  padding: 15px;
  margin-bottom: 12px;
  border: 1px solid #e0e0e0;
  border-radius: 6px;
  display: flex;
  align-items: center;
}
.option-selected {
  background-color: #ebf5ff;
  border-color: #1890ff;
}
.option-id {
  font-weight: bold;
  color: #1890ff;
  margin-right: 10px;
}

/* 提交按钮样式 */
.submit-button {
  margin-top: 30px;
  background: #1890ff;
  color: white;
  border-radius: 6px;
}
.submit-button[disabled] {
  background: #d9d9d9;
}