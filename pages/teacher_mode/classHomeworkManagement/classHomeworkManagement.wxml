<view class="container">
  <!-- 头部 -->
  <view class="header">
    <view class="header-content">
      <text class="title">{{className}} - 作业管理</text>
      <text class="subtitle">共 {{stats.total}} 个作业</text>
    </view>
    <view class="header-actions">
      <button class="btn-primary" bindtap="navigateToAssignChoice">发布作业</button>
    </view>
  </view>

  <!-- 统计卡片 -->
  <view class="stats-container">
    <view class="stat-card">
      <text class="stat-number">{{stats.total}}</text>
      <text class="stat-label">总作业</text>
    </view>
    <view class="stat-card">
      <text class="stat-number">{{stats.active}}</text>
      <text class="stat-label">进行中</text>
    </view>
    <view class="stat-card">
      <text class="stat-number">{{stats.expired}}</text>
      <text class="stat-label">已过期</text>
    </view>
    <view class="stat-card">
      <text class="stat-number">{{stats.graded}}</text>
      <text class="stat-label">已批改</text>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="loading-container" wx:if="{{isLoading}}">
    <view class="loading-spinner"></view>
    <view class="loading-text">加载中...</view>
  </view>

  <!-- 作业列表 -->
  <view class="homework-list" wx:if="{{!isLoading && homeworkList.length > 0}}">
    <view 
      class="homework-card {{item.isExpired ? 'card-expired' : ''}}" 
      wx:for="{{homeworkList}}" 
      wx:key="id">
      
      <view class="card-header" data-homework-id="{{item.id}}" bindtap="navigateToDetail">
        <view class="card-title">{{item.title}}</view>
        <view class="card-status {{item.isExpired ? 'status-expired' : 'status-active'}}">
          {{item.isExpired ? '已截止' : '进行中'}}
        </view>
      </view>

      <view class="card-body" data-homework-id="{{item.id}}" bindtap="navigateToDetail">
        <view class="card-info">
          <text class="info-icon">📅</text>
          <text class="info-label">发布时间:</text>
          <text class="info-value">{{item.created_at}}</text>
        </view>
        <view class="card-info">
          <text class="info-icon">⏰</text>
          <text class="info-label">截止时间:</text>
          <text class="info-value {{item.isExpired ? 'text-expired' : ''}}">{{item.deadline || '未设置截止时间'}}</text>
        </view>
      </view>

      <!-- 操作按钮 -->
      <view class="card-actions">
        <button class="btn-action" data-homework-id="{{item.id}}" data-homework-title="{{item.title}}" bindtap="deleteHomework">
          删除
        </button>
        <button class="btn-action" data-homework-id="{{item.id}}" bindtap="copyHomeworkLink">
          分享
        </button>
        <button class="btn-action" data-homework-id="{{item.id}}" bindtap="viewHomeworkStats">
          统计
        </button>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-container" wx:if="{{!isLoading && homeworkList.length === 0}}">
    <view class="empty-icon">📚</view>
    <view class="empty-text">该班级暂无作业</view>
    <view class="empty-subtext">点击上方"发布作业"按钮开始布置作业</view>
  </view>
</view>
