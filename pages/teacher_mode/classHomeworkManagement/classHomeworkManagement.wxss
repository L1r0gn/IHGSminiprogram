/* /pages/teacherHomeworkPage/classHomeworkManagement/classHomeworkManagement.wxss */
page {
  background-color: #f8f8f8;
}

.container {
  padding: 24rpx;
}
.homework-list {
  width: 90%; 
}
/* 作业卡片 */
.homework-card {
  background-color: #fff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  transition: all 0.2s ease;
}

.homework-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.1);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  width: 75%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-tag {
  font-size: 24rpx;
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.tag-manual {
  background-color: #e6f7f2;
  color: #07c160;
}

.tag-auto {
  background-color: #e6f0ff;
  color: #0052d9;
}

.card-body {
  font-size: 26rpx;
  color: #888;
  margin-bottom: 25rpx;
}

.card-info {
  line-height: 1.5;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.submission-status {
  font-size: 28rpx;
  color: #555;
}

.status-count {
  font-weight: bold;
  color: #fa5151; /* 红色突出 */
  margin-left: 10rpx;
}

.detail-text {
  font-size: 26rpx;
  color: #888;
}

/* 空状态 */
.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 20vh;
}

.empty-image {
  width: 300rpx;
  height: 300rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #555;
  font-weight: bold;
}

.empty-subtext {
  font-size: 26rpx;
  color: #aaa;
  margin-top: 15rpx;
}