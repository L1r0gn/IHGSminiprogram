/* 教师作业管理页面样式 */
page {
  background: linear-gradient(135deg, #f5f7fa 0%, #e4e8ec 100%);
  min-height: 100vh;
}

.container {
  padding: 24rpx;
}

.homework-list {
  width: 100%;
}

/* 作业卡片 */
.homework-card {
  background: linear-gradient(135deg, #ffffff 0%, #fafafa 100%);
  border-radius: 24rpx;
  margin-bottom: 28rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  border: 2rpx solid transparent;
  position: relative;
  overflow: hidden;
}

.homework-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
  border-radius: 24rpx 24rpx 0 0;
}

.homework-card.card-expired::before {
  background: linear-gradient(90deg, #a8a8a8 0%, #d4d4d4 100%);
}

.homework-card:active {
  transform: translateY(-4rpx) scale(0.99);
  box-shadow: 0 12rpx 32rpx rgba(102, 126, 234, 0.15);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #2d3748;
  flex: 1;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  padding-right: 16rpx;
}

.card-status {
  font-size: 22rpx;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-weight: 500;
  white-space: nowrap;
  flex-shrink: 0;
}

.status-active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

.status-expired {
  background: linear-gradient(135deg, #a8a8a8 0%, #d4d4d4 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(168, 168, 168, 0.3);
}

.card-body {
  margin-bottom: 28rpx;
}

.card-info {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #718096;
  margin-bottom: 16rpx;
  line-height: 1.5;
}

.card-info:last-child {
  margin-bottom: 0;
}

.info-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.info-label {
  color: #a0aec0;
  margin-right: 8rpx;
  flex-shrink: 0;
}

.info-value {
  color: #4a5568;
  font-weight: 500;
}

.text-expired {
  color: #e53e3e;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
}

.submission-info {
  display: flex;
  align-items: center;
  font-size: 26rpx;
}

.submission-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.submission-text {
  color: #718096;
  margin-right: 8rpx;
}

.submission-count {
  font-size: 32rpx;
  font-weight: 700;
  color: #667eea;
  margin: 0 4rpx;
}

.submission-total {
  color: #a0aec0;
  font-size: 24rpx;
}

.detail-btn {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #667eea;
  font-weight: 500;
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.1) 100%);
  transition: all 0.2s ease;
}

.detail-btn .arrow-icon {
  font-size: 32rpx;
  margin-left: 4rpx;
  transition: transform 0.2s ease;
}

.homework-card:active .detail-btn .arrow-icon {
  transform: translateX(4rpx);
}

/* 空状态 */
.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  animation: fadeIn 0.6s ease;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.empty-icon {
  font-size: 160rpx;
  margin-bottom: 32rpx;
  opacity: 0.6;
  animation: float 3s ease-in-out infinite;
}

@keyframes float {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-16rpx);
  }
}

.empty-text {
  font-size: 32rpx;
  color: #2d3748;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.empty-subtext {
  font-size: 26rpx;
  color: #a0aec0;
  text-align: center;
  line-height: 1.6;
  max-width: 500rpx;
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 40rpx;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 4rpx solid rgba(102, 126, 234, 0.2);
  border-top-color: #667eea;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 28rpx;
  color: #a0aec0;
}