/* 编辑作业页面样式 */
page {
  background: linear-gradient(135deg, #f5f7fa 0%, #e4e8ec 100%);
  min-height: 100vh;
}

.container {
  padding: 24rpx;
  /* padding-bottom: 160rpx; */
}

.card {
  background: linear-gradient(135deg, #ffffff 0%, #fafafa 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
  width: 80%;
}

.card-header {
  margin-bottom: 32rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.card-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #2d3748;
  position: relative;
  padding-left: 24rpx;
}

.card-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 32rpx;
  background: linear-gradient(180deg, #667eea 0%, #764ba2 100%);
  border-radius: 3rpx;
}

.form-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-item-vertical {
  display: flex;
  flex-direction: column;
  margin-bottom: 32rpx;
}

.form-item-vertical:last-child {
  margin-bottom: 0;
}

.label {
  width: 160rpx;
  font-size: 28rpx;
  color: #4a5568;
  font-weight: 500;
}

.label-title {
  font-size: 28rpx;
  color: #4a5568;
  font-weight: 500;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
}

.required {
  color: #e53e3e;
  margin-left: 4rpx;
  font-size: 28rpx;
}

.input {
  flex: 1;
  text-align: right;
  font-size: 28rpx;
  color: #2d3748;
  font-weight: 500;
}

/* 选择器样式 */
.picker-group {
  flex: 1;
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
}

.picker-box {
  background: linear-gradient(135deg, #f7fafc 0%, #edf2f7 100%);
  padding: 12rpx 24rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #2d3748;
  min-width: 160rpx;
  text-align: center;
  font-weight: 500;
  transition: all 0.2s ease;
}

.picker-box:active {
  opacity: 0.7;
  transform: scale(0.98);
}

/* 标签选择器样式 */
.tags-container {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.tag {
  padding: 10rpx 24rpx;
  background: linear-gradient(135deg, #f7fafc 0%, #edf2f7 100%);
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #718096;
  font-weight: 500;
  transition: all 0.2s ease;
  border: 2rpx solid transparent;
}

.tag:active {
  transform: scale(0.95);
}

.tag-active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

.selected-hint {
  font-size: 24rpx;
  color: #e53e3e;
  margin-top: 8rpx;
}

/* 搜索框样式 */
.search-wrapper {
  position: relative;
  margin-bottom: 20rpx;
}

.search-input {
  width: 100%;
  padding: 20rpx 60rpx 20rpx 24rpx;
  background: linear-gradient(135deg, #f7fafc 0%, #edf2f7 100%);
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #2d3748;
  box-sizing: border-box;
  transition: all 0.2s ease;
}

.search-input:focus {
  background: #ffffff;
  box-shadow: 0 0 0 4rpx rgba(102, 126, 234, 0.1);
}

.search-icon {
  position: absolute;
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 32rpx;
  color: #a0aec0;
}

/* 已选择的知识点 */
.selected-tags-container {
  margin-bottom: 20rpx;
}

.selected-tags-label {
  font-size: 26rpx;
  color: #4a5568;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.selected-tags-wrapper {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag-selected {
  display: flex;
  align-items: center;
  padding: 12rpx 20rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  border-radius: 30rpx;
  font-size: 26rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.25);
}

.tag-remove {
  margin-left: 8rpx;
  font-size: 28rpx;
  opacity: 0.8;
}

.tag-selected:active {
  transform: scale(0.95);
}

/* 知识点列表 */
.knowledge-list {
  max-height: 400rpx;
  overflow-y: auto;
  background: #f7fafc;
  border-radius: 16rpx;
  margin-top: 12rpx;
}

.knowledge-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #e2e8f0;
  transition: all 0.2s ease;
  background: #ffffff;
}

.knowledge-item:last-child {
  border-bottom: none;
}

.knowledge-item:active {
  background: #edf2f7;
}

.knowledge-item.item-selected {
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.05) 0%, rgba(118, 75, 162, 0.05) 100%);
}

.knowledge-name {
  flex: 1;
  font-size: 28rpx;
  color: #2d3748;
}

.knowledge-status {
  font-size: 32rpx;
  color: #667eea;
  font-weight: bold;
  margin-left: 16rpx;
  min-width: 40rpx;
  text-align: center;
}

.empty-hint {
  text-align: center;
  padding: 40rpx 20rpx;
  font-size: 26rpx;
  color: #a0aec0;
}

/* 文本域样式 */
.textarea {
  width: 100%;
  min-height: 240rpx;
  background: linear-gradient(135deg, #f7fafc 0%, #edf2f7 100%);
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #2d3748;
  box-sizing: border-box;
  line-height: 1.6;
}

.word-count {
  text-align: right;
  font-size: 24rpx;
  color: #a0aec0;
  margin-top: 12rpx;
}

/* 底部按钮区域 */
.footer-btn-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 40rpx;
  background: linear-gradient(to top, #f5f7fa 0%, rgba(245, 247, 250, 0.95) 100%);
  border-top: 1rpx solid rgba(0, 0, 0, 0.05);
}

.btn-save {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 44rpx;
  font-weight: 600;
  font-size: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.4);
  transition: all 0.2s ease;
}

.btn-save:active {
  opacity: 0.9;
  transform: scale(0.98);
}