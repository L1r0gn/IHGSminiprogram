<view class="container">
  <!-- 基础信息卡片 -->
  <view class="card">
    <view class="card-header">
      <text class="card-title">基础信息</text>
    </view>

    <view class="form-item">
      <text class="label">作业标题</text>
      <input
        class="input"
        placeholder="请输入作业标题"
        value="{{formData.title}}"
        data-field="title"
        bindinput="onInputChange"
        maxlength="50"
      />
    </view>

    <view class="form-item">
      <text class="label">科目</text>
      <picker
        mode="selector"
        range="{{subjects}}"
        range-key="name"
        value="{{subjectIndex}}"
        bindchange="onSubjectChange"
      >
        <view class="picker-box">
          {{subjectIndex !== null ? subjects[subjectIndex].name : '选择科目'}}
        </view>
      </picker>
    </view>

    <view class="form-item">
      <text class="label">题目类型</text>
      <picker
        mode="selector"
        range="{{problemTypes}}"
        range-key="name"
        value="{{problemTypeIndex}}"
        bindchange="onProblemTypeChange"
      >
        <view class="picker-box">
          {{problemTypeIndex !== null ? problemTypes[problemTypeIndex].name : '选择类型'}}
        </view>
      </picker>
    </view>

    <view class="form-item">
      <text class="label">截止时间</text>
      <view class="picker-group">
        <picker mode="date" value="{{date}}" start="{{today}}" bindchange="onDateChange">
          <view class="picker-box">{{date || '选择日期'}}</view>
        </picker>
        <picker mode="time" value="{{time}}" bindchange="onTimeChange">
          <view class="picker-box">{{time || '选择时间'}}</view>
        </picker>
      </view>
    </view>
  </view>

  <!-- 题目设置卡片 -->
  <view class="card">
    <view class="card-header">
      <text class="card-title">题目设置</text>
    </view>

    <view class="form-item">
      <text class="label">难度</text>
      <picker
        mode="selector"
        range="{{difficultyOptions}}"
        range-key="label"
        value="{{difficultyIndex}}"
        bindchange="onDifficultyChange"
      >
        <view class="picker-box">
          {{difficultyOptions[difficultyIndex].label}}
        </view>
      </picker>
    </view>

    <view class="form-item">
      <text class="label">分值</text>
      <picker
        mode="selector"
        range="{{pointOptions}}"
        bindchange="onPointsChange"
      >
        <view class="picker-box">{{formData.points}} 分</view>
      </picker>
    </view>

    <view class="form-item-vertical">
      <view class="label-title">知识点</view>

      <!-- 搜索框 -->
      <view class="search-wrapper">
        <input
          class="search-input"
          placeholder="搜索知识点..."
          value="{{searchKeyword}}"
          bindinput="onSearchInput"
          bindconfirm="showKnowledgeList"
        />
        <text class="search-icon">🔍</text>
      </view>

      <!-- 选中的知识点 -->
      <view class="selected-tags-container" wx:if="{{formData.knowledge_points.length > 0}}">
        <view class="selected-tags-label">已选择：</view>
        <view class="selected-tags-wrapper">
          <view
            wx:for="{{selectedKnowledgePoints}}"
            wx:key="id"
            class="tag tag-selected"
            data-id="{{item.id}}"
            bindtap="removeKnowledgePoint"
          >
            {{item.name}}
            <text class="tag-remove">✕</text>
          </view>
        </view>
      </view>

      <!-- 可选择的知识点列表 - 搜索后显示 -->
      <view class="knowledge-list" wx:if="{{showKnowledgeList && filteredKnowledgePoints.length > 0}}">
        <view
          wx:for="{{filteredKnowledgePoints}}"
          wx:key="id"
          class="knowledge-item {{formData.knowledge_points.includes(item.id) ? 'item-selected' : ''}}"
          data-id="{{item.id}}"
          data-item="{{item}}"
          bindtap="addKnowledgePoint"
        >
          <text class="knowledge-name">{{item.name}}</text>
          <text class="knowledge-status">{{formData.knowledge_points.includes(item.id) ? '✓' : '+'}}</text>
        </view>
      </view>

      <view class="empty-hint" wx:if="{{showKnowledgeList && filteredKnowledgePoints.length === 0}}">
        {{searchKeyword ? '未找到匹配的知识点' : '暂无知识点'}}
      </view>
    </view>
  </view>

  <!-- 题目内容卡片 -->
  <view class="card">
    <view class="card-header">
      <text class="card-title">题目内容</text>
    </view>

    <view class="form-item-vertical">
      <view class="label-title">题目描述</view>
      <textarea
        class="textarea"
        placeholder="请输入作业详细描述..."
        value="{{formData.description}}"
        data-field="description"
        bindinput="onInputChange"
        maxlength="500"
      />
      <view class="word-count">{{formData.description.length || 0}}/500</view>
    </view>

    <view class="form-item-vertical">
      <view class="label-title">题目内容 <text class="required">*</text></view>
      <textarea
        class="textarea"
        placeholder="请输入题目内容..."
        value="{{formData.content}}"
        data-field="content"
        bindinput="onInputChange"
        maxlength="2000"
      />
      <view class="word-count">{{formData.content.length || 0}}/2000</view>
    </view>

    <view class="form-item-vertical">
      <view class="label-title">正确答案 <text class="required">*</text></view>
      <textarea
        class="textarea"
        placeholder="请输入正确答案..."
        value="{{formData.answer}}"
        data-field="answer"
        bindinput="onInputChange"
        maxlength="1000"
      />
      <view class="word-count">{{formData.answer.length || 0}}/1000</view>
    </view>

    <view class="form-item-vertical">
      <view class="label-title">答案解析</view>
      <textarea
        class="textarea"
        placeholder="请输入答案解析（可选）..."
        value="{{formData.explanation}}"
        data-field="explanation"
        bindinput="onInputChange"
        maxlength="1000"
      />
      <view class="word-count">{{formData.explanation.length || 0}}/1000</view>
    </view>

    <view class="form-item-vertical">
      <view class="label-title">自定义评分提示词</view>
      <textarea
        class="textarea"
        placeholder="可输入对AI评分的特殊要求，如关注特定得分点、评分偏重等..."
        value="{{formData.custom_prompt}}"
        data-field="custom_prompt"
        bindinput="onInputChange"
        maxlength="500"
      />
      <view class="word-count">{{formData.custom_prompt.length || 0}}/500</view>

    </view>
  </view>

  <!-- 底部按钮 -->
  <view class="footer-btn-area">
    <button class="btn-save" bindtap="submitHomework">
      {{isEditMode ? '保存修改' : '发布作业'}}
    </button>
  </view>
</view>