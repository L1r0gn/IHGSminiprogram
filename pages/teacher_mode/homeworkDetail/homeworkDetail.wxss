/* pages/teacherHomeworkPage/homeworkDetail/homeworkDetail.wxss */
.homework-detail-container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 140rpx;
}

/* 作业信息卡片样式 */
.homework-info-card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.homework-title-section {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.homework-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
  margin-right: 20rpx;
}

.status-tag {
  padding: 8rpx 16rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.status-tag.ongoing {
  background-color: #e6f7ff;
  color: #1890ff;
}

.status-tag.expired {
  background-color: #fff2f0;
  color: #ff4d4f;
}

.status-tag.draft {
  background-color: #f5f5f5;
  color: #999;
}

.homework-meta {
  margin-bottom: 24rpx;
}

.meta-item {
  display: flex;
  margin-bottom: 12rpx;
  font-size: 28rpx;
}

.meta-label {
  color: #666;
  width: 160rpx;
}

.meta-value {
  color: #333;
  flex: 1;
}

.homework-description {
  font-size: 28rpx;
}

.description-label {
  color: #666;
  margin-bottom: 12rpx;
  display: block;
}

.description-content {
  color: #333;
  line-height: 1.6;
}

/* 提交统计卡片样式 */
.submit-stats-card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.stats-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
}

.stats-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stat-number {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #666;
}

.stat-divider {
  width: 2rpx;
  height: 40rpx;
  background-color: #ebedf0;
}

.submit-progress {
  width: 100%;
}

/* 学生列表卡片样式 */
.student-list-card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.list-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.list-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.filter-tabs {
  display: flex;
  background-color: #f5f5f5;
  border-radius: 32rpx;
  padding: 4rpx;
}

.filter-tab {
  padding: 12rpx 20rpx;
  font-size: 24rpx;
  color: #666;
  border-radius: 28rpx;
  display: flex; /* 使用flex布局 */
}

.filter-tab.active {
  background-color: #07c160;
  color: #fff;
}

.student-list {
  max-height: 600rpx;
  overflow-y: auto;
}

.student-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.student-item:last-child {
  border-bottom: none;
}

.student-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  overflow: hidden;
  margin-right: 20rpx;
}

.student-avatar image {
  width: 100%;
  height: 100%;
}

.student-info {
  flex: 1;
}

.student-name {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.student-id {
  font-size: 24rpx;
  color: #999;
}

.submit-status {
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  margin-right: 20rpx;
}

.submit-status.submitted {
  background-color: #e6f7ff;
  color: #1890ff;
}

.submit-status.unsubmitted {
  background-color: #fff2f0;
  color: #ff4d4f;
}

.arrow-icon {
  width: 32rpx;
  height: 32rpx;
}

.arrow-icon image {
  width: 100%;
  height: 100%;
}

/* 底部操作栏样式 */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  padding: 20rpx 30rpx;
  display: flex;
  justify-content: space-between;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.action-bar button {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.btn-secondary {
  background-color: #f5f5f5;
  color: #333;
  margin-right: 20rpx;
}

.btn-primary {
  background-color: #07c160;
  color: #fff;
}