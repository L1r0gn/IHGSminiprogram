<!--pages/teacher_mode/manualInput/manualInput.wxml-->
<view class="container">
  
  <!-- 卡片一：基础信息 -->
  <view class="card">
    <view class="card-header">基础信息</view>
    
    <!-- 题目标题 -->
    <view class="form-item">
      <text class="label">标题</text>
      <input 
        class="input" 
        placeholder="请输入作业标题" 
        value="{{title}}"
        bindinput="onTitleInput"
      />
    </view>

    <!-- 目标班级 -->
    <view class="form-item">
      <text class="label">目标班级</text>
      <picker 
        range="{{classList}}" 
        range-key="name" 
        value="{{classIndex}}" 
        bindchange="onClassChange"
      >
        <view class="picker-content {{classIndex >= 0 ? '' : 'placeholder'}}">
          {{classIndex >= 0 ? classList[classIndex].name : '请选择目标班级'}}
        </view>
      </picker>
    </view>

    <!-- 截止时间 -->
    <view class="form-item">
      <text class="label">截止时间</text>
      <picker 
        mode="date" 
        value="{{deadlineDate}}" 
        start="{{today}}" 
        bindchange="onDateChange"
      >
        <view class="picker-content {{deadlineDate ? '' : 'placeholder'}}">
          {{deadlineDate || '请选择日期'}}
        </view>
      </picker>
      <picker 
        mode="time" 
        value="{{deadlineTime}}" 
        bindchange="onTimeChange"
        style="margin-left: 20rpx;"
      >
        <view class="picker-content {{deadlineTime ? '' : 'placeholder'}}">
          {{deadlineTime || '请选择时间'}}
        </view>
      </picker>
    </view>
  </view>

  <!-- 卡片二：题目详情 -->
  <view class="card">
    <view class="card-header">题目详情</view>

    <!-- 科目 -->
    <view class="form-item">
      <text class="label">科目</text>
      <picker 
        range="{{subjects}}" 
        range-key="name" 
        value="{{subjectIndex}}" 
        bindchange="onSubjectChange"
      >
        <view class="picker-content {{subjectIndex >= 0 ? '' : 'placeholder'}}">
          {{subjectIndex >= 0 ? subjects[subjectIndex].name : '请选择科目'}}
        </view>
      </picker>
    </view>

    <!-- 题型 -->
    <view class="form-item">
      <text class="label">题型</text>
      <picker 
        range="{{problemTypes}}" 
        range-key="name" 
        value="{{problemTypeIndex}}" 
        bindchange="onProblemTypeChange"
      >
        <view class="picker-content {{problemTypeIndex >= 0 ? '' : 'placeholder'}}">
          {{problemTypeIndex >= 0 ? problemTypes[problemTypeIndex].name : '请选择题型'}}
        </view>
      </picker>
    </view>

    <!-- 难度 -->
    <view class="form-item">
      <text class="label">难度</text>
      <slider class="slider" min="1" max="5" value="{{difficulty}}" show-value bindchange="onDifficultyChange" style="flex: 1; margin-left: 20rpx;" />
    </view>

    <!-- 分值 -->
    <view class="form-item">
      <text class="label">分值</text>
      <input class="input" type="number" value="{{points}}" bindinput="onPointsInput" placeholder="默认10分" />
    </view>

    <!-- 预计时间 -->
    <view class="form-item">
      <text class="label">预计用时(分)</text>
      <input class="input" type="number" value="{{estimated_time}}" bindinput="onTimeInput" placeholder="分钟" />
    </view>

    <!-- 题目描述 -->
    <view class="form-item-vertical">
      <text class="label">题目描述</text>
      <textarea 
        class="textarea" 
        placeholder="请输入题目描述..." 
        value="{{content}}"
        bindinput="onContentInput"
        maxlength="1000"
      />
      <!-- 图片上传 -->
      <view class="image-list">
        <view class="image-item" wx:for="{{contentImages}}" wx:key="*this">
          <image src="{{item}}" mode="aspectFill" bindtap="previewImage" data-url="{{item}}"></image>
          <view class="remove-btn" catchtap="removeImage" data-index="{{index}}">×</view>
        </view>
        <view class="add-image-btn" bindtap="uploadImage">
          <text>+</text>
        </view>
      </view>
    </view>

    <!-- 动态区域 -->
    <block wx:if="{{isChoice}}">
      <view class="form-item-vertical">
        <view class="label-row">
          <text class="label">选项设置</text>
          <view class="add-option-btn" bindtap="addOption">添加选项</view>
        </view>
        <view class="options-list">
          <view class="option-item" wx:for="{{options}}" wx:key="index">
            <text class="option-key">{{item.key}}</text>
            <input 
              class="option-input" 
              placeholder="请输入选项内容" 
              value="{{item.value}}" 
              data-index="{{index}}"
              bindinput="onOptionInput"
            />
            <view class="remove-option-btn" data-index="{{index}}" bindtap="removeOption" wx:if="{{options.length > 2}}">删除</view>
          </view>
        </view>
      </view>
      <view class="form-item">
        <text class="label">正确答案</text>
        <picker 
          range="{{options}}" 
          range-key="key" 
          value="{{answerIndex}}" 
          bindchange="onAnswerChange"
        >
          <view class="picker-content {{answerIndex >= 0 ? '' : 'placeholder'}}">
            {{answerIndex >= 0 ? options[answerIndex].key : '请选择正确选项'}}
          </view>
        </picker>
      </view>
    </block>
    
    <block wx:else>
      <view class="form-item-vertical">
        <text class="label">参考答案</text>
        <textarea 
          class="textarea" 
          placeholder="请输入参考答案..." 
          value="{{answer}}"
          bindinput="onAnswerInput"
        />
      </view>
    </block>

  </view>

  <!-- 底部操作栏 -->
  <view class="footer-bar">
    <button class="btn-delete" bindtap="onDelete" wx:if="{{assignmentId}}">删除</button>
    <button class="btn-draft" bindtap="onSaveDraft">保存草稿</button>
    <button class="btn-publish" bindtap="onPublish">立即发布</button>
  </view>

</view>