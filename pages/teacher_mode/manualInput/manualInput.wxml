<!--pages/teacherHomeworkPage/manualInput/manualInput.wxml-->
<view class="container">
  <view class="header">
    <text class="title">手动输入题目</text>
    <text class="subtitle">请填写题目相关信息</text>
  </view>

  <scroll-view class="form-container" scroll-y>
    <!-- 题目标题 -->
    <view class="form-section">
      <text class="section-label">题目标题</text>
      <input 
        class="title-input" 
        placeholder="请输入题目标题" 
        value="{{title}}"
        bindinput="onTitleInput"
        maxlength="200"
      />
      <text class="char-count">{{title.length}}/200</text>
    </view>

    <!-- 题目内容 -->
    <view class="form-section">
      <text class="section-label">题目内容</text>
      <textarea 
        class="content-textarea" 
        placeholder="请输入题目内容..." 
        value="{{content}}"
        bindinput="onContentInput"
        maxlength="1000"
        show-confirm-bar="{{false}}"
      />
      <text class="char-count">{{content.length}}/1000</text>
    </view>

    <!-- 题目类型 -->
    <view class="form-section">
      <text class="section-label">题目类型</text>
      <picker 
        range="{{problemTypes}}" 
        range-key="name" 
        value="{{problemTypeIndex}}" 
        bindchange="onProblemTypeChange"
      >
        <view class="picker">
          <text class="{{problemTypeIndex >= 0 ? 'picker-text' : 'picker-placeholder'}}">
            {{problemTypeIndex >= 0 ? problemTypes[problemTypeIndex].name : '请选择题目类型'}}
          </text>
          <!-- <image src="/images/arrow-down.png" class="picker-arrow"></image> -->
        </view>
      </picker>
    </view>

    <!-- 所属科目 -->
    <view class="form-section">
      <text class="section-label">所属科目</text>
      <picker 
        range="{{subjects}}" 
        range-key="name" 
        value="{{subjectIndex}}" 
        bindchange="onSubjectChange"
      >
        <view class="picker">
          <text class="{{subjectIndex >= 0 ? 'picker-text' : 'picker-placeholder'}}">
            {{subjectIndex >= 0 ? subjects[subjectIndex].name : '请选择所属科目'}}
          </text>
          <!-- <image src="/images/arrow-down.png" class="picker-arrow"></image> -->
        </view>
      </picker>
    </view>

    <!-- 难度选择 -->
    <view class="form-section">
      <text class="section-label">题目难度</text>
      <view class="difficulty-buttons">
        <button 
          class="difficulty-btn {{difficulty === 1 ? 'active' : ''}}" 
          data-level="1"
          bindtap="onDifficultyChange"
        >
          简单
        </button>
        <button 
          class="difficulty-btn {{difficulty === 2 ? 'active' : ''}}" 
          data-level="2"
          bindtap="onDifficultyChange"
        >
          中等
        </button>
        <button 
          class="difficulty-btn {{difficulty === 3 ? 'active' : ''}}" 
          data-level="3"
          bindtap="onDifficultyChange"
        >
          困难
        </button>
      </view>
    </view>

    <!-- 题目标签 -->
    <view class="form-section">
      <text class="section-label">题目标签</text>
      <view class="tags-container">
        <view 
          class="tag {{selectedTags.indexOf(tag.id) > -1 ? 'selected' : ''}}" 
          wx:for="{{tags}}"
          wx:key="id"
          data-tag="{{tag}}"
          bindtap="onTagToggle"
        >
          <text class="tag-text">{{tag.name}}</text>
        </view>
      </view>
    </view>

    <!-- 预估时间 -->
    <view class="form-section">
      <text class="section-label">预估耗时(分钟)</text>
      <input 
        class="time-input" 
        type="number" 
        placeholder="请输入预估时间" 
        value="{{estimatedTime}}"
        bindinput="onTimeInput"
      />
    </view>

    <!-- 分值设置 -->
    <view class="form-section">
      <text class="section-label">题目分值</text>
      <input 
        class="points-input" 
        type="number" 
        placeholder="请输入题目分值" 
        value="{{points}}"
        bindinput="onPointsInput"
      />
    </view>

    <!-- 答案设置 -->
    <view class="form-section">
      <text class="section-label">题目答案</text>
      <textarea 
        class="answer-textarea" 
        placeholder="请输入题目答案..." 
        value="{{answer}}"
        bindinput="onAnswerInput"
        maxlength="500"
        show-confirm-bar="{{false}}"
      />
      <text class="char-count">{{answer.length}}/500</text>
    </view>

    <!-- 答案解析 -->
    <view class="form-section">
      <text class="section-label">答案解析</text>
      <textarea 
        class="explanation-textarea" 
        placeholder="请输入答案解析..." 
        value="{{explanation}}"
        bindinput="onExplanationInput"
        maxlength="1000"
        show-confirm-bar="{{false}}"
      />
      <text class="char-count">{{explanation.length}}/1000</text>
    </view>

    <!-- 附件上传 -->
    <view class="form-section">
      <text class="section-label">题目附件</text>
      <view class="attachment-container">
        <view class="attachment-item" wx:for="{{attachments}}" wx:key="*this">
          <text class="attachment-name">{{item}}</text>
          <text class="attachment-remove" data-index="{{index}}" bindtap="onRemoveAttachment">×</text>
        </view>
        <view class="attachment-upload" bindtap="onUploadAttachment">
          <text class="upload-text">上传附件</text>
        </view>
      </view>
    </view>
  </scroll-view>

  <!-- 底部操作按钮 -->
  <view class="action-buttons">
    
    <button class="save-btn" bindtap="onSaveDraft">保存草稿</button>
    <button class="submit-btn" bindtap="onSubmit">提交题目</button>
    <button class="cancel-btn" bindtap="onCancel">取消</button>
  </view>
</view>