/* pages/teacher_mode/manualInput/manualInput.wxss */
page {
  background-color: #f5f7fa;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Segoe UI, Arial, Roboto, 'PingFang SC', sans-serif;
  box-sizing: border-box;
}

.container {
  min-height: 100vh;
  padding: 30rpx;
  padding-bottom: 180rpx; /* 留出底部按钮空间 */
}

/* --- 卡片样式 --- */
.card {
  width: 80%;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s ease;
}

.card-header {
  font-size: 34rpx;
  font-weight: 700;
  color: #2c3e50;
  margin-bottom: 36rpx;
  padding-left: 20rpx;
  position: relative;
  display: flex;
  align-items: center;
}

/* 标题左侧装饰条 */
.card-header::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 8rpx;
  height: 32rpx;
  background: linear-gradient(to bottom, #4a90e2, #63a4ff);
  border-radius: 4rpx;
}

/* --- 表单项 --- */
.form-item {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-item-vertical {
  display: flex;
  flex-direction: column;
  margin-bottom: 32rpx;
}

.label {
  width: 160rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: #7f8c8d;
  flex-shrink: 0;
}

.label-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

/* 输入框 & 选择器 */
.input, .picker-content {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  background: #f9fafc;
  border: 2rpx solid #edf2f7;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #2c3e50;
  transition: all 0.3s;
}

.picker-content {
  display: flex;
  align-items: center;
  justify-content: space-between; /* 让箭头靠右，如果有的话 */
}

.picker-content.placeholder {
  color: #bdc3c7;
}

/* 文本域 */
.textarea {
  width: 100%;
  height: 240rpx;
  background: #f9fafc;
  border: 2rpx solid #edf2f7;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #2c3e50;
  margin-top: 16rpx;
  box-sizing: border-box;
  line-height: 1.6;
}

/* --- 图片上传 --- */
.image-list {
  display: flex;
  flex-wrap: wrap;
  margin-top: 24rpx;
  gap: 24rpx;
  justify-content: center;
}

.image-item {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}

.image-item image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.remove-btn {
  position: absolute;
  top: 0;
  right: 0;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0,0,0,0.6);
  color: #fff;
  border-bottom-left-radius: 12rpx;
  text-align: center;
  line-height: 40rpx;
  font-size: 28rpx;
  font-weight: bold;
}

.add-image-btn {
  width: 160rpx;
  height: 160rpx;
  background: #f9fafc;
  border: 2rpx dashed #cbd5e0;
  border-radius: 12rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  transition: all 0.2s;
}

.add-image-btn:active {
  background: #edf2f7;
}

.add-image-btn text {
  font-size: 60rpx;
  color: #a0aec0;
  font-weight: 300;
}

/* --- 动态选项 --- */
.add-option-btn {
  font-size: 24rpx;
  color: #4a90e2;
  padding: 10rpx 24rpx;
  background: #eaf2ff;
  border-radius: 30rpx;
  font-weight: 600;
}

.options-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.option-item {
  display: flex;
  align-items: center;
}

.option-key {
  width: 64rpx;
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  background: #edf2f7;
  border-radius: 50%;
  font-size: 28rpx;
  font-weight: bold;
  color: #4a5568;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.option-input {
  flex: 1;
  height: 88rpx;
  background: #f9fafc;
  border: 2rpx solid #edf2f7;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #2c3e50;
  margin-right: 20rpx;
}

.remove-option-btn {
  color: #e53e3e;
  font-size: 26rpx;
  padding: 16rpx;
  font-weight: 500;
}

/* --- 底部操作栏 (悬浮胶囊风格) --- */
.footer-bar {
  position: fixed;
  bottom: 40rpx;
  left: 30rpx;
  right: 30rpx;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10px);
  padding: 20rpx;
  border-radius: 60rpx;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.1);
  display: flex;
  align-items: center;
  justify-content: space-between;
  z-index: 100;
  /* 适配全面屏 */
  padding-bottom: calc(20rpx + constant(safe-area-inset-bottom)/2);
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom)/2);
}

.btn-draft, .btn-publish, .btn-delete {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  margin: 0 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.btn-delete {
  background: #fff2f0;
  color: #ff4d4f;
  flex: 0.8; /* 删除按钮稍微小一点 */
}

.btn-draft {
  background: #fff;
  border: 2rpx solid #e0e6ed;
  color: #4a5568;
}

.btn-publish {
  background: linear-gradient(135deg, #4a90e2, #56ccf2);
  color: #ffffff;
  box-shadow: 0 6rpx 16rpx rgba(74, 144, 226, 0.3);
}

.btn-publish:active {
  opacity: 0.9;
  transform: scale(0.98);
}