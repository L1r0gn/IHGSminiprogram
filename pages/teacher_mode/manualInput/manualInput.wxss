/* pages/teacherHomeworkPage/manualInput/manualInput.wxss */
.container {
  background-color: #f5f7fa;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

.header {
  background: white;
  padding: 30rpx;
  text-align: center;
  border-bottom: 1rpx solid #eee;
}

.title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #2c3e50;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #7f8c8d;
}

.form-container {
  flex: 1;
  padding: 30rpx;
}

.form-section {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.section-label {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #2c3e50;
  margin-bottom: 20rpx;
}

.title-input, .time-input, .points-input {
  width: 100%;
  padding: 20rpx;
  border: 2rpx solid #ecf0f1;
  border-radius: 10rpx;
  font-size: 28rpx;
}

.content-textarea, .answer-textarea, .explanation-textarea {
  width: 100%;
  min-height: 200rpx;
  padding: 20rpx;
  border: 2rpx solid #ecf0f1;
  border-radius: 10rpx;
  font-size: 28rpx;
  line-height: 1.5;
}

.char-count {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: #95a5a6;
  margin-top: 10rpx;
}

.picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  border: 2rpx solid #ecf0f1;
  border-radius: 10rpx;
}

.picker-text {
  font-size: 28rpx;
  color: #2c3e50;
}

.picker-placeholder {
  font-size: 28rpx;
  color: #95a5a6;
}

.picker-arrow {
  width: 30rpx;
  height: 30rpx;
}

.difficulty-buttons {
  display: flex;
  gap: 20rpx;
}

.difficulty-btn {
  flex: 1;
  background: #ecf0f1;
  color: #7f8c8d;
  border: none;
  border-radius: 10rpx;
  padding: 20rpx;
  font-size: 28rpx;
}

.difficulty-btn.active {
  background: #3498db;
  color: white;
}

.difficulty-btn:after {
  border: none;
}

.tags-container {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.tag {
  padding: 15rpx 25rpx;
  background: #ecf0f1;
  border-radius: 30rpx;
  border: 2rpx solid transparent;
}

.tag.selected {
  background: #3498db;
  border-color: #2980b9;
}

.tag-text {
  font-size: 26rpx;
  color: #7f8c8d;
}

.tag.selected .tag-text {
  color: white;
}

.attachment-container {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.attachment-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 10rpx;
}

.attachment-name {
  font-size: 28rpx;
  color: #2c3e50;
}

.attachment-remove {
  font-size: 36rpx;
  color: #e74c3c;
  padding: 0 10rpx;
}

.attachment-upload {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx;
  border: 2rpx dashed #bdc3c7;
  border-radius: 10rpx;
  background: #f8f9fa;
}

.upload-icon {
  width: 60rpx;
  height: 60rpx;
  margin-bottom: 20rpx;
}

.upload-text {
  font-size: 34rpx;
  color: #7f8c8d;
}

.action-buttons {
  padding: 30rpx;
  background: white;
  border-top: 1rpx solid #eee;
  gap: 20rpx;
}

.cancel-btn, .save-btn, .submit-btn {
  flex: 1;
  border: none;
  border-radius: 10rpx;
  padding: 25rpx;
  margin:10px;
  font-size: 30rpx;
  font-weight: 600;
}

.cancel-btn {
  background: #ecf0f1;
  color: #7f8c8d;
}

.save-btn {
  background: #f39c12;
  color: white;
}

.submit-btn {
  background: #2ecc71;
  color: white;
}

.cancel-btn:after, .save-btn:after, .submit-btn:after {
  border: none;
}