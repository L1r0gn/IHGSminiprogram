<!--pages/teacher_mode/assignChoice/assignChoice.wxml-->
<view class="container">
  <view class="header">
    <text class="title">布置作业</text>
    <text class="subtitle">{{className}} - 请选择布置作业的方式</text>
  </view>
  
  <!-- 发布方式选择 -->
  <view class="section">
    <view class="section-title">选择发布方式</view>
    <view class="options-grid">
      <view class="option-card primary" bindtap="navigateToManualInput">
        <view class="option-icon">✍️</view>
        <view class="option-content">
          <text class="option-title">手动输入题目</text>
          <text class="option-desc">创建全新题目，支持文本、图片、公式等多种格式</text>
        </view>
        <view class="option-arrow">›</view>
      </view>
      
      <view class="option-card secondary" bindtap="navigateToSelectQuestions">
        <view class="option-icon">📚</view>
        <view class="option-content">
          <text class="option-title">从题库选择</text>
          <text class="option-desc">从现有题库中选择题目，支持搜索和批量布置</text>
        </view>
        <view class="option-arrow">›</view>
      </view>
    </view>
  </view>
  
  
  <!-- 作业管理 -->
  <view class="section">
    <view class="section-title">作业管理</view>
    <view class="options-grid">
      <view class="option-card tertiary" bindtap="navigateToClassHomeworkManagement">
        <view class="option-icon">📋</view>
        <view class="option-content">
          <text class="option-title">班级作业管理</text>
          <text class="option-desc">查看和管理班级所有作业</text>
        </view>
        <view class="option-arrow">›</view>
      </view>
    </view>
  </view>
</view>
