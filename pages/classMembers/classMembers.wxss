/* pages/classMembers/classMembers.wxss */
page {
  background-color: #f5f7fa;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
}

.container {
  display: block;
  min-height: 100vh;
  padding: 0;
  padding-bottom: 60rpx;
  box-sizing: border-box;
}

/* 页面容器 */
.content-wrapper {
  padding: 40rpx;
}

/* 顶部区域 */
.header-section {
  position: relative;
  margin-bottom: 40rpx;
  animation: fadeIn 0.6s ease-out;
}

.header-bg {
  height: 200rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-bottom-left-radius: 20rpx;
  border-bottom-right-radius: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
}

.class-info-card {
  margin: -120rpx 30rpx 0;
  background-color: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
}

.class-title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.class-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a1a;
  letter-spacing: -0.5rpx;
}

.member-badge {
  background: #d1fae5;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.count {
  font-size: 24rpx;
  color: #059669;
  font-weight: 600;
}

.class-desc {
  font-size: 28rpx;
  color: #64748b;
  line-height: 1.5;
}

/* 成员列表 */
.member-list-container {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding: 0 40rpx;
}

.member-card {
  background: white;
  border-radius: 24rpx;
  padding: 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
  overflow: hidden;
  animation: fadeInUp 0.5s ease-out both;
}

.member-card:active {
  transform: translateY(-4rpx);
  box-shadow: 0 16rpx 40rpx rgba(0, 0, 0, 0.12);
}

.member-card:nth-child(1) { animation-delay: 0.1s; }
.member-card:nth-child(2) { animation-delay: 0.2s; }
.member-card:nth-child(3) { animation-delay: 0.3s; }
.member-card:nth-child(4) { animation-delay: 0.4s; }
.member-card:nth-child(5) { animation-delay: 0.5s; }

.member-main {
  display: flex;
  align-items: center;
  flex: 1;
}

.avatar-wrapper {
  position: relative;
  margin-right: 28rpx;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background-color: #e2e8f0;
  border: 4rpx solid #fff;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.teacher-crown {
  position: absolute;
  right: -4rpx;
  bottom: -4rpx;
  background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #fff;
  box-shadow: 0 2rpx 8rpx rgba(245, 158, 11, 0.3);
}

.teacher-crown .iconfont {
  font-size: 20rpx;
  color: #fff;
}

.name-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-right: 16rpx;
}

.role-tag {
  font-size: 20rpx;
  color: #fff;
  background: linear-gradient(90deg, #34d399, #10b981);
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  font-weight: 600;
}

.student-id {
  font-size: 24rpx;
  color: #64748b;
}

/* 移除按钮 */
.remove-btn {
  padding: 12rpx 28rpx;
  border-radius: 44rpx;
  background-color: #fee2e2;
  border: 1rpx solid #fca5a5;
  transition: all 0.3s ease;
}

.remove-btn text {
  font-size: 24rpx;
  color: #dc2626;
  font-weight: 600;
}

.remove-btn-active {
  background-color: #dc2626 !important;
  border-color: #dc2626 !important;
  box-shadow: 0 4rpx 12rpx rgba(220, 38, 38, 0.3);
}

.remove-btn-active text {
  color: #fff !important;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 60rpx;
  background: white;
  border-radius: 28rpx;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.08);
  margin: 0 40rpx;
  animation: fadeIn 0.6s ease-out;
}

.empty-icon-wrapper {
  background-color: #f1f5f9;
  padding: 40rpx;
  border-radius: 50%;
  margin-bottom: 24rpx;
}

.empty-icon {
  width: 120rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 32rpx;
  color: #1a1a1a;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.empty-subtext {
  font-size: 28rpx;
  color: #94a3b8;
}

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 60rpx;
  background: white;
  border-radius: 28rpx;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.08);
  margin: 0 40rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid #e2e8f0;
  border-top-color: #667eea;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 24rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #64748b;
}

/* 动画 */
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes spin {
  to { transform: rotate(360deg); }
}