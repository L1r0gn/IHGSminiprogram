/* pages/courses/courses.wxss - 简约风格 */
page {
  background-color: #f5f7fa;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
}

.page-container {
  min-height: 100vh;
}

.content-wrapper {
  padding: 40rpx;
}

.page-header {
  margin-bottom: 40rpx;
  padding: 20rpx 0;
  animation: fadeIn 0.6s ease-out;
}

.page-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #1a1a1a;
  display: block;
  margin-bottom: 12rpx;
}

.page-subtitle {
  font-size: 28rpx;
  color: #999;
  display: block;
}

/* 创建课程按钮 */
.create-btn {
  background: linear-gradient(135deg, #667eea, #764ba2);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  color: white;
  box-shadow: 0 4rpx 20rpx rgba(102, 126, 234, 0.3);
}

.btn-icon {
  font-size: 44rpx;
  margin-right: 20rpx;
}

.btn-text {
  flex: 1;
}

.btn-title {
  font-size: 32rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 8rpx;
}

.btn-desc {
  font-size: 24rpx;
  opacity: 0.9;
  display: block;
}

.btn-arrow {
  font-size: 36rpx;
  font-weight: bold;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 60rpx;
  background: white;
  border-radius: 28rpx;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.08);
  animation: fadeIn 0.8s ease-out 0.3s both;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
  animation: breathe 2s ease-in-out infinite;
}

.empty-text {
  font-size: 32rpx;
  color: #64748b;
  margin-bottom: 40rpx;
}

.empty-tip {
  font-size: 24rpx;
  color: #999;
  display: block;
}

.join-btn {
  width: 300rpx;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 20rpx rgba(102, 126, 234, 0.3);
  transition: all 0.3s ease;
}

.join-btn::after {
  border: none;
}

.join-btn:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.4);
}

/* 课程列表 */
.course-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* 教师端课程卡片 */
.course-item {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
  border-left: 6rpx solid #1890ff;
}

/* 学生端课程卡片 */
.course-item.student-card {
  display: flex;
  align-items: center;
  padding: 32rpx;
  background: white;
  border-radius: 28rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
  border-left: none;
}

.course-item.student-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.05) 0%, rgba(118, 75, 162, 0.05) 100%);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.course-item.student-card:active {
  transform: translateY(-8rpx) scale(1.02);
  box-shadow: 0 16rpx 40rpx rgba(102, 126, 234, 0.2);
}

.course-item.student-card:active::before {
  opacity: 1;
}

.course-item.student-card .course-arrow {
  font-size: 40rpx;
  color: #cbd5e1;
  margin-left: 24rpx;
  transition: transform 0.3s ease;
}

.course-item.student-card:active .course-arrow {
  transform: translateX(10rpx);
  color: #667eea;
}

.course-item.student-card .course-name {
  color: #1e293b;
  transition: color 0.3s ease;
}

.course-item.student-card:active .course-name {
  color: #667eea;
}

.course-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 25rpx;
}

.course-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.course-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.course-code {
  font-size: 24rpx;
  color: #666;
  display: block;
}

.course-stats {
  background: #e6f7ff;
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
}

.student-count {
  font-size: 24rpx;
  color: #1890ff;
  font-weight: 500;
}

/* 学生端卡片描述样式 */
.course-desc {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.teacher,
.count {
  font-size: 26rpx;
  color: #64748b;
}

.course-arrow {
  font-size: 40rpx;
  color: #cbd5e1;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  flex: 1;
  background: #f5f5f5;
  border: 2rpx solid #e8e8e8;
  border-radius: 10rpx;
  padding: 20rpx 0;
  font-size: 24rpx;
  color: #333;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.action-btn::after {
  border: none;
}

.action-btn:active {
  background: #e8e8e8;
}

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 60rpx;
  background: white;
  border-radius: 28rpx;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.08);
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid #e2e8f0;
  border-top-color: #667eea;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 28rpx;
  color: #64748b;
}

/* 模态框样式 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 9999;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: white;
  border-radius: 20rpx;
  width: 85%;
  max-width: 600rpx;
  max-height: 80vh;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.modal-close {
  font-size: 36rpx;
  color: #999;
  padding: 10rpx;
}

.modal-body {
  padding: 30rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.form-group {
  margin-bottom: 30rpx;
}

.form-label {
  display: block;
  font-size: 26rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 15rpx;
}

.form-input,
.form-textarea {
  border: 2rpx solid #e8e8e8;
  border-radius: 10rpx;
  padding: 30rpx;
  font-size: 26rpx;
  background: #fafafa;
}

.form-textarea {
  height: 120rpx;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 0 30rpx 30rpx;
}

.modal-btn {
  flex: 1;
  border: none;
  border-radius: 10rpx;
  padding: 24rpx 0;
  font-size: 26rpx;
  font-weight: 500;
}

.modal-btn::after {
  border: none;
}

.cancel-btn {
  background: #f5f5f5;
  color: #666;
}

.cancel-btn:active {
  background: #e8e8e8;
}

.confirm-btn {
  background: #1890ff;
  color: white;
}

.confirm-btn:active {
  background: #096dd9;
}

.textarea-wrapper {
  position: relative;
  width: 100%;
}

.word-count {
  position: absolute;
  right: 20rpx;
  bottom: 10rpx;
  font-size: 22rpx;
  color: #999;
  z-index: 1;
}

@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

@keyframes breathe {
  0%, 100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.05);
  }
}
