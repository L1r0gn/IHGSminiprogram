.container {
  background: #fafbfc;
  min-height: 100vh;
  padding-top: 80rpx;
}

/* 顶部搜索栏 */
.search-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 10px 16px;
  z-index: 100;
  display: flex;
  align-items: center;
  gap: 12px;
  box-shadow: 0 2px 8px rgba(102, 126, 234, 0.06);
}

/* 8:2布局容器 */
.search-bar-wrap {
  display: flex;
  align-items: center;
  flex: 1;
}

.search-bar {
  flex: 8;
  background: #f5f6fa;
  border-radius: 20px;
  padding: 8px 14px;
  display: flex;
  align-items: center;
}

.search-input {
  flex: 1;
  margin: 0 10px;
  font-size: 15px;
}

/* 筛选按钮基础样式 */
.filter-btn {
  font-size: 13px;
  color: #666;
  padding: 6px 10px;
  background: #f5f5f5;
  border-radius: 14px;
  max-width: 100px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.filter-btn.active {
  color: #1890ff;
  background: #e6f7ff;
}

/* 右侧筛选按钮（8:2的2格） */
.search-bar-wrap .filter-btn {
  flex: 2;
  max-width: none;
  color: #fff;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  box-shadow: 0 2px 8px rgba(102, 126, 234, 0.2);
  padding: 8px 12px;
  margin-left: 8px;
  text-align: center;
}

.arrow {
  font-size: 10px;
  margin-left: 2px;
}

/* 随机入口 */
.random-entry {
  position: fixed;
  bottom: 24px;
  left: 16px;
  right: 16px;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  padding: 14px 20px;
  border-radius: 12px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 15px;
  font-weight: 500;
  box-shadow: 0 4px 20px rgba(102, 126, 234, 0.35);
  z-index: 99;
  animation: fadeInUp 0.5s ease-out;
}

.random-entry:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.go-icon {
  font-size: 18px;
  font-weight: 300;
  opacity: 0.8;
}

/* 列表区域 */
.question-list {
  height: calc(100vh - 56px);
  padding: 16px;
  padding-bottom: 80px;
  box-sizing: border-box;
}

.question-item {
  background: #fff;
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 12px;
  box-shadow: 0 2px 8px rgba(102, 126, 234, 0.08);
  animation: fadeInUp 0.4s ease-out backwards;
}

.question-item:active {
  transform: scale(0.98);
  box-shadow: 0 1px 4px rgba(102, 126, 234, 0.12);
}

.q-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
}

.q-tags {
  display: flex;
  gap: 6px;
}

.tag {
  font-size: 10px;
  padding: 3px 8px;
  border-radius: 10px;
  font-weight: 500;
}
.tag.type { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: #fff; }
.tag.diff { background: #fff3e0; color: #ff9800; }

.q-id {
  font-size: 12px;
  color: #b8b8b8;
}

.q-title {
  font-size: 15px;
  font-weight: 600;
  color: #2c3e50;
  margin-bottom: 8px;
  line-height: 1.4;
}

.q-preview {
  font-size: 13px;
  color: #7f8c8d;
  line-height: 1.6;
  margin-bottom: 10px;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.q-footer {
  border-top: 1px solid #f0f0f0;
  padding-top: 10px;
  font-size: 12px;
  color: #667eea;
  display: flex;
  align-items: center;
  gap: 4px;
}

.loading-tip {
  text-align: center;
  padding: 20px;
  color: #95a5a6;
  font-size: 13px;
}

.empty-state {
  text-align: center;
  padding: 60px 20px;
  color: #95a5a6;
  font-size: 14px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12px;
}

.empty-state .sub-text {
  font-size: 12px;
  color: #bdc3c7;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* ========== 筛选弹窗样式（选中常亮核心） ========== */
.filter-modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 9999;
}

.modal-mask {
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  background: #fff;
  border-top-left-radius: 20px;
  border-top-right-radius: 20px;
  max-height: 80vh;
  overflow-y: auto;
  box-shadow: 0 -2px 12px rgba(102, 126, 234, 0.1);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px 20px;
  border-bottom: 1px solid #f5f6fa;
}

.modal-title {
  font-size: 16px;
  font-weight: 600;
  color: #2c3e50;
}

.clear-all-btn {
  font-size: 14px;
  color: #667eea;
  background: none;
  padding: 0;
  font-weight: 500;
}

.filter-section {
  padding: 16px 20px;
}

.section-title {
  font-size: 15px;
  color: #2c3e50;
  margin-bottom: 12px;
  display: block;
  font-weight: 500;
}

.option-group {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

/* 筛选选项默认样式 */
.option-item {
  padding: 6px 16px;
  background: #f5f6fa;
  border-radius: 16px;
  font-size: 14px;
  color: #666;
  box-shadow: 0 1px 2px rgba(102, 126, 234, 0.05);
  transition: all 0.1s ease;
}

/* 选中常亮样式（核心） */
.option-item.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  box-shadow: 0 2px 8px rgba(102, 126, 234, 0.2);
  border: 1px solid rgba(255, 255, 255, 0.8);
  font-weight: 500;
}

/* 点击反馈 */
.option-item:active {
  transform: scale(0.95);
}

.modal-footer {
  display: flex;
  padding: 16px 20px;
  gap: 12px;
  border-top: 1px solid #f5f6fa;
}

.cancel-btn {
  flex: 1;
  height: 44px;
  line-height: 44px;
  border: 1px solid #e0e0e0;
  color: #666;
  border-radius: 22px;
  font-size: 15px;
  background: #fff;
}

.confirm-btn {
  flex: 1;
  height: 44px;
  line-height: 44px;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 22px;
  font-size: 15px;
  font-weight: 500;
  box-shadow: 0 2px 8px rgba(102, 126, 234, 0.2);
}