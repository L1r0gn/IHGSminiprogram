/* pages/question/search/search.wxss */
.container {
  background: #fafbfc;
  min-height: 100vh;
  padding-top: 80rpx;
}

/* 顶部搜索栏 */
.search-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 10px 16px;
  z-index: 100;
  display: flex;
  align-items: center;
  gap: 12px;
  box-shadow: 0 2px 8px rgba(102, 126, 234, 0.06);
}

.search-bar {
  flex: 1;
  background: #f5f6fa;
  border-radius: 20px;
  padding: 8px 14px;
  display: flex;
  align-items: center;
}

.search-input {
  flex: 1;
  margin: 0 10px;
  font-size: 15px;
}

.filter-btn {
  font-size: 13px;
  color: #666;
  padding: 6px 10px;
  background: #f5f5f5;
  border-radius: 14px;
  max-width: 100px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.filter-btn.active {
  color: #1890ff;
  background: #e6f7ff;
}

.arrow {
  font-size: 10px;
  margin-left: 2px;
}

/* 随机入口 */
.random-entry {
  position: fixed;
  bottom: 24px;
  left: 16px;
  right: 16px;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  padding: 14px 20px;
  border-radius: 12px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 15px;
  font-weight: 500;
  box-shadow: 0 4px 20px rgba(102, 126, 234, 0.35);
  z-index: 99;
  animation: fadeInUp 0.5s ease-out;
}

.random-entry:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.go-icon {
  font-size: 18px;
  font-weight: 300;
  opacity: 0.8;
}

/* 列表区域 */
.question-list {
  height: calc(100vh - 56px);
  padding: 16px;
  padding-bottom: 80px;
  box-sizing: border-box;
}

.question-item {
  background: #fff;
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 12px;
  box-shadow: 0 2px 8px rgba(102, 126, 234, 0.08);
  animation: fadeInUp 0.4s ease-out backwards;
}

.question-item:active {
  transform: scale(0.98);
  box-shadow: 0 1px 4px rgba(102, 126, 234, 0.12);
}

.q-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
}

.q-tags {
  display: flex;
  gap: 6px;
}

.tag {
  font-size: 10px;
  padding: 3px 8px;
  border-radius: 10px;
  font-weight: 500;
}
.tag.type { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: #fff; }
.tag.diff { background: #fff3e0; color: #ff9800; }

.q-id {
  font-size: 12px;
  color: #b8b8b8;
}

.q-title {
  font-size: 15px;
  font-weight: 600;
  color: #2c3e50;
  margin-bottom: 8px;
  line-height: 1.4;
}

.q-preview {
  font-size: 13px;
  color: #7f8c8d;
  line-height: 1.6;
  margin-bottom: 10px;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.q-footer {
  border-top: 1px solid #f0f0f0;
  padding-top: 10px;
  font-size: 12px;
  color: #667eea;
  display: flex;
  align-items: center;
  gap: 4px;
}

.loading-tip {
  text-align: center;
  padding: 20px;
  color: #95a5a6;
  font-size: 13px;
}

.empty-state {
  text-align: center;
  padding: 60px 20px;
  color: #95a5a6;
  font-size: 14px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12px;
}

.empty-state .sub-text {
  font-size: 12px;
  color: #bdc3c7;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}