<view class="container" wx:if="{{!isLoading}}">

<view class="status-header {{homeworkDetail.status}} {{isOverdue ? 'overdue' : ''}}">
  <view class="status-icon">
    <text wx:if="{{homeworkDetail.status === 'PENDING' && !isOverdue}}">📝</text>
    <text wx:if="{{homeworkDetail.status === 'SUBMITTED' && redo}}">📝</text>
    <text wx:elif="{{homeworkDetail.status === 'PENDING' && isOverdue}}">⚠️</text>
    <text wx:elif="{{homeworkDetail.status === 'SUBMITTED'}}">✅</text>
    <text wx:elif="{{homeworkDetail.status === 'ACCEPT'}}">✅</text>
    <text wx:elif="{{homeworkDetail.status === 'WRONG_ANSWER'}}">❌</text>
    <text wx:elif="{{homeworkDetail.status === 'GRADED'}}">💯</text>
  </view>
  <view class="status-text">
    <text wx:if="{{homeworkDetail.status === 'PENDING' && !isOverdue}}">作业进行中</text>
    <text wx:elif="{{homeworkDetail.status === 'PENDING' && isOverdue}}">已过截止时间</text>
    <text wx:elif="{{homeworkDetail.status === 'SUBMITTED'}}">已提交，等待批改</text>
    <text wx:elif="{{homeworkDetail.status === 'ACCEPT'}}">答案正确</text>
    <text wx:elif="{{homeworkDetail.status === 'WRONG_ANSWER'}}">答案错误</text>
    <text wx:elif="{{homeworkDetail.status === 'GRADED'}}">作业已批改</text>
  </view>
  <view class="status-score" wx:if="{{homeworkDetail.status === 'GRADED'||'WRONG_ANSWER'||'ACCEPT'}}">
    <text class="score-num">{{homeworkDetail.score||0}}</text>
    <text class="score-total">/ {{homeworkDetail.problem_points}}</text>
  </view>
</view>

<view class="card info-card">
  <view class="card-header">
    <view class="assignment-title">{{homeworkDetail.assignment_title}}</view>
  </view>
  <view class="card-body">
    <view class="info-group">
      <view class="info-item">
        <text class="info-label">👨‍🏫 教师</text>
        <text class="info-value">{{homeworkDetail.teacher_name}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">📅 截止</text>
        <text class="info-value {{isOverdue ? 'text-red' : ''}}">{{homeworkDetail.deadline || '无截止日期'}}</text>
      </view>
    </view>
  </view>
</view>

<view class="card problem-card">
  <view class="card-header">
    <text class="card-title-text">题目内容</text>
    <view class="points-tag">{{homeworkDetail.problem_points}} 分</view>
  </view>
  <view class="card-body">
    <view class="problem-content">
      <text selectable="true">{{homeworkDetail.problem_content}}</text>
    </view>
  </view>
</view>

<!-- 做题页面 -->
<block wx:if="{{homeworkDetail.status === 'PENDING' && !isOverdue || isRedo}}">
  <block wx:if="{{homeworkDetail.problem_type === '选择'}}">
    <view class="card answer-card">
      <view class="card-header">
        <text class="card-title-text">请作答</text>
      </view>
      <view class="options-container">
        <block wx:for="{{options}}" wx:key="id">
          <view 
            class="option-item {{item.selected ? 'option-selected' : ''}}"
            bindtap="selectAnswer" 
            data-id="{{item.id}}"
          >
            <text class="option-id">{{item.id}}</text>
          </view>
        </block>
      </view>
    </view>
  </block>
  
  <block wx:elif="{{homeworkDetail.problem_type === '主观' || homeworkDetail.problem_type === '简答' || homeworkDetail.problem_type === '填空'}}">
    <view class="card answer-card">
      <view class="card-header">
        <text class="card-title-text">请作答</text>
      </view>
      <view class="card-body">
        <textarea 
          class="answer-textarea"
          placeholder="请输入你的答案..."
          placeholder-class="textarea-placeholder"
          value="{{studentAnswerContent}}"
          bindinput="onAnswerInput"
          maxlength="{{-1}}"
        ></textarea>
      </view>
    </view>
  </block>

  <block wx:elif="{{homeworkDetail.problem_type === '图片' || homeworkDetail.problem_type === '拍照'}}">
    <view class="card answer-card">
      <view class="card-header">
        <text class="card-title-text">请作答</text>
      </view>
      <view class="subjective-container">
        <view class="image-preview-container">
          <image 
            wx:if="{{SUBMITTED_image_path}}" 
            class="image-preview" 
            src="{{SUBMITTED_image_path}}" 
            mode="aspectFit" 
            bindtap="previewImage"
          ></image>
          <text wx:else class="upload-tip">暂无图片</text>
        </view>
        <button 
          class="upload-button" 
          bindtap="uploadImage"
        >
          {{ SUBMITTED_image_path ? '重新上传' : '拍照 / 选择图片上传' }}
        </button>
<view class="upload-tip">请将手写答案拍照上传</view>
      </view>
    </view>
  </block>
</block>


<view class="card SUBMITTED-card" wx:if="{{homeworkDetail.status === 'SUBMITTED' || homeworkDetail.status === 'GRADED'}}">
  <view class="card-header">
    <text class="card-title-text">我的提交</text>
    <text class="submit-time">{{homeworkDetail.SUBMITTED_at || ''}}</text>
  </view>
  <view class="card-body">
    <view class="SUBMITTED-content">
      <text selectable="true">{{homeworkDetail.student_answer_content || '(空)'}}</text>
    </view>
  </view>
</view> 

<view class="card feedback-card" wx:if="{{homeworkDetail.status === 'GRADED'}}">
    <view class="card-header">
      <text class="card-title-text">教师评语</text>
    </view>
    <view class="card-body">
      <view class="feedback-content">
        <text selectable="true">{{homeworkDetail.feedback || '暂无评语'}}</text>
      </view>
    </view>
  </view>
</view>

<view class="footer-bar-placeholder"></view> <view class="footer-bar safe-area-bottom" wx:if="{{!isLoading}}">
  <button   
    class="action-btn primary-btn" 
    hover-class="btn-hover"
    bindtap="onSubmit"
    wx:if="{{homeworkDetail.status === 'PENDING' && !isOverdue || isRedo}}"
  >
    提交作业
  </button>
  <button 
    class="action-btn disabled-btn" 
    disabled
    wx:if="{{homeworkDetail.status === 'PENDING' && isOverdue}}"
  >
    已截止
  </button>
<button 
  class="action-btn outline-btn" 
  hover-class="outline-hover"
  bindtap="onBack"
  wx:if="{{true || homeworkDetail.status == 'SUBMITTED'||'GRADED'||'WRONG_ANSWER'||'ACCEPT'}}"
>
  返回列表
</button>
</view>

<!-- 加载中动画 -->
<view class="loading-mask" wx:if="{{isLoading}}">
  <view class="loading-spinner"></view>
  <text>加载中...</text>
</view>