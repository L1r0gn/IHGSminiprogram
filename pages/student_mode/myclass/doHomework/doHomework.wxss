/* pages/doHomework/doHomework.wxss */
page {
  background-color: #f5f7fa; /* 更清爽的浅灰蓝背景 */
  color: #333;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica,
    Segoe UI, Arial, Roboto, 'PingFang SC', 'miui', 'Hiragino Sans GB', 'Microsoft Yahei',
    sans-serif;
  box-sizing: border-box;
}

.container {
  padding: 30rpx 30rpx 180rpx; /* 底部留出更多空间给固定按钮 */
}

/* --- 通用卡片样式 (升级版) --- */
.card {
  width: 90%;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 36rpx;
  margin-bottom: 10rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.05); /* 更柔和、扩散的阴影 */
  transition: all 0.3s ease;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 28rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #f0f0f0; /* 更淡的分割线 */
}

.card-title-text {
  font-size: 34rpx;
  font-weight: 700;
  color: #2c3e50;
  position: relative;
  padding-left: 24rpx;
}

/* 标题前的小装饰条 (更有质感的渐变) */
.card-title-text::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 8rpx;
  height: 34rpx;
  background: linear-gradient(to bottom, #4a90e2, #63a4ff);
  border-radius: 6rpx;
}

/* --- 顶部状态栏 (全新设计) --- */
.status-header {
  width: 90%;
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: linear-gradient(135deg, #5b86e5, #36d1dc); /* 蓝青渐变，更清新 */
  color: #fff;
  border-radius: 30rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 12rpx 30rpx rgba(54, 209, 220, 0.3);
  position: relative;
  overflow: hidden;
}

/* 状态栏背景纹理 (可选，增加质感) */
.status-header::after {
  content: '';
  position: absolute;
  top: -50%;
  right: -20%;
  width: 300rpx;
  height: 300rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.status-header.submitted {
  background: linear-gradient(135deg, #43cea2, #185a9d); /* 蓝绿渐变 */
  box-shadow: 0 12rpx 30rpx rgba(67, 206, 162, 0.3);
}

.status-header.graded {
  background: linear-gradient(135deg, #ff9966, #ff5e62); /* 橙红渐变 */
  box-shadow: 0 12rpx 30rpx rgba(255, 94, 98, 0.3);
}

.status-header.overdue,
.status-header.pending.overdue {
  background: linear-gradient(135deg, #cb2d3e, #ef473a); /* 深红渐变 */
  box-shadow: 0 12rpx 30rpx rgba(239, 71, 58, 0.3);
}

.status-icon {
  font-size: 64rpx;
  margin-right: 30rpx;
  background: rgba(255, 255, 255, 0.2);
  width: 100rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  backdrop-filter: blur(5px);
}

.status-text {
  flex: 1;
  font-size: 36rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.status-score {
  display: flex;
  align-items: baseline;
  background: rgba(0, 0, 0, 0.1);
  padding: 10rpx 24rpx;
  border-radius: 16rpx;
}

.score-num {
  font-size: 60rpx;
  font-weight: 800;
  line-height: 1;
}

.score-total {
  font-size: 28rpx;
  opacity: 0.9;
  margin-left: 8rpx;
  font-weight: 500;
}

/* --- 1. 作业信息卡片 --- */
.info-card .card-header {
  border-bottom: none;
  padding-bottom: 0;
  margin-bottom: 24rpx;
}

.assignment-title {
  font-size: 40rpx;
  font-weight: 800;
  color: #1a1a1a;
  line-height: 1.4;
}

.card-body .info-group { /* 新增：信息分组 */
  display: flex;
  flex-wrap: wrap;
  margin: 0 -15rpx; /* 抵消子元素的 padding */
}

.info-item {
  display: flex;
  align-items: center;
  padding: 15rpx;
  font-size: 28rpx;
  background: #f9fafc;
  border-radius: 12rpx;
  margin: 10rpx 15rpx; /* 增加间距 */
  flex: 1 1 40%; /* 自适应宽度 */
  min-width: 250rpx;
}

.info-label {
  color: #7f8c8d;
  margin-right: 16rpx;
}

.info-value {
  color: #2c3e50;
  font-weight: 600;
}

.text-red {
  color: #e74c3c;
}

/* --- 2. 题目卡片 --- */
.points-tag {
  background: #eaf2ff;
  color: #4a90e2;
  font-size: 26rpx;
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  font-weight: 700;
}

.problem-content {
  font-size: 32rpx;
  line-height: 1.8;
  color: #34495e;
  white-space: pre-wrap;
  background: #f9fafc;
  padding: 24rpx;
  border-radius: 16rpx;
  border: 1rpx solid #eee;
}

/* --- 3. 作答卡片 --- */
.answer-card.disabled {
  opacity: 0.8;
}

.answer-textarea {
  width: 100%;
  min-height: 400rpx;
  padding: 30rpx;
  font-size: 32rpx;
  line-height: 1.6;
  color: #2c3e50;
  background-color: #f4f6f9; /* 更深一点的背景，突出输入区域 */
  border-radius: 20rpx;
  border: 2rpx solid transparent;
  box-sizing: border-box;
  transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
}

.answer-textarea:focus {
  background-color: #fff;
  border-color: #4a90e2;
  box-shadow: 0 0 0 6rpx rgba(74, 144, 226, 0.1); /* 聚焦时的光晕效果 */
}

.textarea-placeholder {
  color: #bdc3c7;
}

.word-count {
  text-align: right;
  font-size: 26rpx;
  color: #95a5a6;
  margin-top: 16rpx;
  font-weight: 500;
}

/* --- 4. 已提交卡片 --- */
.submit-time {
  font-size: 26rpx;
  color: #95a5a6;
  background: #f0f2f5;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.submitted-content {
  background-color: #f4f6f9;
  padding: 30rpx;
  border-radius: 20rpx;
  font-size: 32rpx;
  color: #57606f;
  line-height: 1.7;
  white-space: pre-wrap;
  border-left: 8rpx solid #ced6e0; /* 左侧装饰线 */
}

/* --- 5. 反馈卡片 --- */
.feedback-card .card-title-text::before {
  background: linear-gradient(to bottom, #f39c12, #e67e22); /* 橙色渐变 */
}

.feedback-content {
  background-color: #fffaf0; /* 暖色调背景 */
  padding: 30rpx;
  border-radius: 20rpx;
  font-size: 32rpx;
  color: #d35400;
  line-height: 1.7;
  white-space: pre-wrap;
  border: 1rpx solid #ffe0b2;
  position: relative;
}

/* 引用图标装饰 */
.feedback-content::before {
  content: '"';
  position: absolute;
  top: 10rpx;
  left: 20rpx;
  font-size: 80rpx;
  color: rgba(211, 84, 0, 0.1);
  font-family: serif;
}

/* --- 底部操作栏 (悬浮感增强) --- */
.footer-bar {
  position: fixed;
  bottom: 40rpx; /* 悬浮在底部之上 */
  left: 30rpx;
  right: 30rpx;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(10px);
  padding: 20rpx;
  border-radius: 60rpx; /* 大圆角 */
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.1);
  z-index: 100;
  display: flex;
  justify-content: center;
  /* 适配全面屏底部 */
  padding-bottom: calc(20rpx + constant(safe-area-inset-bottom)/2);
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom)/2);
}

.action-btn {
  border-radius: 50rpx;
  font-size: 34rpx;
  font-weight: 600;
  height: 96rpx;
  line-height: 96rpx;
  width: 100%; /* 撑满容器 */
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
  letter-spacing: 2rpx;
}

.action-btn::after {
  border: none;
}

.primary-btn {
  background: linear-gradient(135deg, #4a90e2, #56ccf2); /* 更亮丽的蓝色渐变 */
  color: #fff;
  box-shadow: 0 8rpx 20rpx rgba(74, 144, 226, 0.4);
}

.primary-btn.btn-hover {
  transform: translateY(2rpx);
  box-shadow: 0 4rpx 10rpx rgba(74, 144, 226, 0.3);
}

.disabled-btn {
  background: #e0e0e0 !important;
  color: #aab0b6 !important;
  box-shadow: none;
}

.outline-btn {
  background: #fff;
  color: #57606f;
  border: 2rpx solid #dfe4ea;
}

.outline-btn.outline-hover {
  background: #f1f2f6;
}

/* --- 加载动画 (保持简洁) --- */
.loading-mask {
  /* ... 保持原有 ... */
  background: rgba(255, 255, 255, 0.8); /* 轻微透明 */
  backdrop-filter: blur(5px);
}


/* --- 选择题样式 --- */
.options-container {
  display: flex;
  padding: 0 20px;
  margin-top: 20px;
  justify-content: space-around;
  flex-wrap: wrap;
}
.option-item {
  width: 40px;
  height: 40px;
  padding:10px;
  margin-bottom: 12px;
  border: 1px solid #e0e0e0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}
.option-selected {
  background-color: #ebf5ff;
  border-color: #1890ff;
  transform: scale(1.05);
}
.option-id {
  font-weight: bold;
  color: #1890ff;
  font-size: 20px;
}

/* --- 主观题（图片上传）样式 --- */
.subjective-container {
  padding: 0 20px;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 20px;
}
.image-preview-container {
  width: 100%;
  min-height: 150px;
  border: 2rpx dashed #d9d9d9;
  border-radius: 8px;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 20px;
  background-color: #fafafa;
  padding: 10px;
}
.image-preview {
  max-width: 100%;
  max-height: 400px;
  border-radius: 4px;
}
.upload-button {
  background-color: #ffffff;
  color: #1890ff;
  border: 1px solid #1890ff !important;
  border-radius: 6px;
  padding: 10px 20px;
  font-size: 16px;
  width: 80%;
}
.upload-button:active {
  background-color: #f0f8ff;
}
.upload-tip {
  font-size: 12px;
  color: #999;
  margin-top: 10px;
}
