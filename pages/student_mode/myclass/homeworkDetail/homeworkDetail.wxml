<view class="container" wx:if="{{submission}}">
  
  <view class="card header-card">
    <view class="title-row">
      <text class="problem-title">{{submission.problem_title}}</text>
    </view>
    <view class="info-row">
      <text class="time">提交时间: {{submission.submitted_time}}</text>
      <view class="status-badge {{submission.status === 'ACCEPTED' ? 'success' : 'warning'}}">
        {{submission.status}}
      </view>
    </view>
    <view class="score-display" wx:if="{{submission.score !== null}}">
      <text class="score-label">最终得分</text>
      <text class="score-value">{{submission.score}}</text>
    </view>
  </view>

  <view class="card content-card">
    <view class="card-header" style="font-size: large;">我的作答</view>
    
    <view class="answer-box" wx:if="{{submission.problem_type === '选择' && submission.choose_answer}}">
      <text>选择选项：{{submission.choose_answer}}</text>
    </view>
    
    <view class="answer-box" wx:if="{{submission.submitted_text}}">
      <text>{{submission.submitted_text}}</text>
    </view>

    <view class="image-box" wx:if="{{submission.submitted_image !== 'http://127.0.0.1:8000/media/default_submissionImage.png'}}">
      <image 
        src="{{submission.submitted_image}}" 
        mode="widthFix" 
        class="submitted-img"
        bindtap="previewImage"
      ></image>
      <view class="tip">点击图片可预览大图</view>
    </view>

    <view wx:if="{{! submission.choose_answer && !submission.submitted_text && (submission.submitted_image === 'http://127.0.0.1:8000/media/default_submissionImage.png')}}" class="empty-tip">
      (未检测到提交内容)
    </view>
  </view>

  <view class="card feedback-card">
    <view class="card-header" style="font-size: large;">AI/教师 反馈</view>
    
    <view class="feedback-item">
      <text class="label">得分：</text>
      <text class="content">{{submission.score || '出现问题，暂无得分'}}</text>
    </view>

    <view class="feedback-item">
      <text class="label">评分理由：</text>
      <text class="content">{{submission.justification || '暂无详细理由'}}</text>
    </view>

    <view class="feedback-item" wx:if="{{submission.feedback}}">
      <text class="label">详细评语：</text>
      <text class="content">{{submission.feedback}}</text>
    </view>
  </view>
</view>