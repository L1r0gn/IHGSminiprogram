/* pages/classHomework/classHomework.wxss */
/* 班级头部 */
.class-header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  padding: 60rpx 40rpx 40rpx;
  margin: 30rpx 30rpx 20rpx; /* 上下左右都有间距 */
  border-radius: 20rpx; /* 完整圆角 */
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.1);
  margin-bottom: 30px;
  /* 移除 width，让 margin 控制宽度 */
}

.class-name {
  font-size: 44rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.class-code {
  font-size: 28rpx;
  opacity: 0.9;
}

/* 班级信息卡片 */
.class-info-card {
  background: white;
  margin: -30rpx 30rpx 30rpx;
  border-radius: 20rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.1);
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #666;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

/* 作业区域 */
.homework-section {
  background: white;
  margin: 0 30rpx;
  border-radius: 20rpx;
  padding: 40rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.homework-count {
  font-size: 24rpx;
  color: #666;
}

/* 筛选标签 */
.filter-tabs {
  display: flex;
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 8rpx;
  margin-bottom: 30rpx;
}

.filter-tab {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  font-size: 26rpx;
  color: #666;
  border-radius: 8rpx;
  transition: all 0.3s;
}

.filter-tab.active {
  background: white;
  color: #1890ff;
  font-weight: 500;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

/* 作业卡片 */
.homework-list {
  margin-bottom: 40rpx;
}

.homework-card {
  background: #fafafa;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  border-left: 8rpx solid #1890ff;
}

.homework-card.pending {
  border-left-color: #faad14;
}

.homework-card.submitted {
  border-left-color: #52c41a;
}

.homework-card.graded {
  border-left-color: #1890ff;
}

.homework-card.expired {
  border-left-color: #d9d9d9;
  opacity: 0.7;
}

.homework-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.homework-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
  margin-right: 20rpx;
}

.homework-status {
  font-size: 22rpx;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  white-space: nowrap;
}

.homework-status.PENDING {
  background: #fff7e6;
  color: #fa8c16;
}

.homework-status.SUBMITTED {
  background: #f6ffed;
  color: #52c41a;
}

.homework-status.GRADED {
  background: #e6f7ff;
  color: #1890ff;
}

.homework-status.EXPIRED {
  background: #f5f5f5;
  color: #8c8c8c;
}

.homework-content {
  margin-bottom: 20rpx;
}

.homework-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.homework-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  font-size: 22rpx;
  color: #8c8c8c;
}

.meta-icon {
  margin-right: 8rpx;
}

/* 操作按钮 */
.homework-actions {
  display: flex;
  justify-content: flex-end;
}

.homework-actions button {
  padding: 16rpx 32rpx;
  font-size: 24rpx;
  border-radius: 8rpx;
  border: none;
}

.btn-primary {
  background: #1890ff;
  color: white;
}

.btn-secondary {
  background: #f0f0f0;
  color: rgb(31, 31, 31);
  
}

.btn-success {
  background: #52c41a;
  color: white;
}

.btn-disabled {
  background: #d9d9d9;
  color: #8c8c8c;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80rpx 0;
}

.empty-image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #8c8c8c;
}