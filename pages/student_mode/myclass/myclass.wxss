/* pages/myClass/myClass.wxss - 简约风格 */
page {
  background-color: #f5f7fa;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
}

.page-container {
  min-height: 100vh;
}

.content-wrapper {
  padding: 40rpx;
}

.page-header {
  margin-bottom: 40rpx;
  padding: 20rpx 0;
  animation: fadeIn 0.6s ease-out;
}

.page-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #1a1a1a;
  display: block;
  margin-bottom: 12rpx;
}

.page-subtitle {
  font-size: 28rpx;
  color: #999;
  display: block;
}

/* 加入班级区域 */
.join-section {
  background: #fff;
  border-radius: 28rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
  animation: fadeInUp 0.6s ease-out 0.2s both;
}

.join-section::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.05) 0%, rgba(118, 75, 162, 0.05) 100%);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.join-section:active {
  transform: translateY(-8rpx) scale(1.02);
  box-shadow: 0 16rpx 40rpx rgba(102, 126, 234, 0.2);
}

.join-section:active::before {
  opacity: 1;
}

.join-text {
  flex: 1;
}

.join-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1e293b;
  display: block;
  margin-bottom: 8rpx;
}

.join-desc {
  font-size: 26rpx;
  color: #64748b;
  display: block;
}

.join-arrow {
  font-size: 48rpx;
  color: #cbd5e1;
  margin-left: 24rpx;
  transition: all 0.3s ease;
}

.join-section:active .join-arrow {
  transform: translateX(10rpx);
  color: #667eea;
}

/* 班级列表 */
.class-section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1e293b;
  margin-bottom: 32rpx;
  display: block;
}

.class-grid {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.class-card {
  background: #fff;
  border-radius: 28rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

/* 交错淡入动画 */
.class-card:nth-child(1) {
  animation: fadeInUp 0.6s ease-out 0.1s both;
}

.class-card:nth-child(2) {
  animation: fadeInUp 0.6s ease-out 0.2s both;
}

.class-card:nth-child(3) {
  animation: fadeInUp 0.6s ease-out 0.3s both;
}

.class-card:nth-child(4) {
  animation: fadeInUp 0.6s ease-out 0.4s both;
}

.class-card:nth-child(5) {
  animation: fadeInUp 0.6s ease-out 0.5s both;
}

.class-card:nth-child(n+6) {
  animation: fadeInUp 0.6s ease-out 0.6s both;
}

.class-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.05) 0%, rgba(118, 75, 162, 0.05) 100%);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.class-card:active {
  transform: translateY(-8rpx) scale(1.02);
  box-shadow: 0 16rpx 40rpx rgba(102, 126, 234, 0.2);
}

.class-card:active::before {
  opacity: 1;
}

.class-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 32rpx;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
}

.class-card:active .class-icon {
  transform: scale(1.1) rotate(5deg);
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.2);
}

.icon-text {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
}

.class-info {
  flex: 1;
  min-width: 0;
}

.class-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #1e293b;
  display: block;
  margin-bottom: 16rpx;
  line-height: 1.4;
  transition: color 0.3s ease;
}

.class-card:active .class-name {
  color: #667eea;
}

.class-code {
  font-size: 26rpx;
  color: #64748b;
  display: block;
  margin-bottom: 8rpx;
}

.class-meta {
  display: flex;
  gap: 12rpx;
}

.meta-item {
  font-size: 24rpx;
  color: #94a3b8;
  background: #f5f7fa;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 60rpx;
  background: white;
  border-radius: 28rpx;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.08);
  animation: fadeIn 0.8s ease-out 0.3s both;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
  animation: breathe 2s ease-in-out infinite;
}

.empty-text {
  font-size: 32rpx;
  color: #64748b;
  margin-bottom: 40rpx;
}

.empty-btn {
  width: 300rpx;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 20rpx rgba(102, 126, 234, 0.3);
  transition: all 0.3s ease;
}

.empty-btn::after {
  border: none;
}

.empty-btn:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.4);
}

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 60rpx;
  background: white;
  border-radius: 28rpx;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.08);
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid #e2e8f0;
  border-top-color: #667eea;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 28rpx;
  color: #64748b;
}

/* 基础动画 */
@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes breathe {
  0%, 100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.05);
  }
}

/* 加入班级弹窗样式 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
  padding: 40rpx;
  box-sizing: border-box;
}

.modal-container {
  background: white;
  border-radius: 28rpx;
  width: 100%;
  max-width: 600rpx;
  overflow: hidden;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.2);
  animation: modalSlideIn 0.3s ease-out;
}

@keyframes modalSlideIn {
  from {
    opacity: 0;
    transform: translateY(-50rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #e2e8f0;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.modal-close {
  font-size: 48rpx;
  color: #94a3b8;
  padding: 16rpx;
  margin: -16rpx;
  line-height: 1;
  transition: color 0.3s ease;
}

.modal-close:active {
  color: #667eea;
}

.modal-body {
  padding: 32rpx;
}

.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #1e293b;
  margin-bottom: 20rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  border: 2rpx solid #e2e8f0;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  background: #fafafa;
  box-sizing: border-box;
  transition: all 0.3s ease;
}

.form-input:focus {
  border-color: #667eea;
  background: #fff;
  box-shadow: 0 0 0 4rpx rgba(102, 126, 234, 0.1);
}

.tip-text {
  font-size: 24rpx;
  color: #94a3b8;
  line-height: 1.5;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 0 32rpx 32rpx;
}

.modal-btn {
  flex: 1;
  border: none;
  border-radius: 16rpx;
  padding: 24rpx 0;
  font-size: 28rpx;
  font-weight: 600;
  transition: all 0.3s ease;
  height: 88rpx;
  line-height: 40rpx;
}

.modal-btn::after {
  border: none;
}

.modal-btn.cancel {
  background: #f5f7fa;
  color: #64748b;
}

.modal-btn.cancel:active {
  background: #e2e8f0;
  transform: scale(0.98);
}

.modal-btn.confirm {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  box-shadow: 0 8rpx 20rpx rgba(102, 126, 234, 0.3);
}

.modal-btn.confirm:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.4);
}

.modal-btn.confirm[disabled] {
  background: #e2e8f0;
  color: #94a3b8;
  box-shadow: none;
}
