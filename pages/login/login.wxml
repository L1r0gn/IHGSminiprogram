<view class="page-container">
  <view class="content-wrapper">
    <!-- 页面头部 -->
    <view class="page-header">
      <view class="app-title">智能作业批改系统</view>
      <view class="app-subtitle">智 能 · 高 效 · 便 捷</view>
    </view>

    <!-- 登录卡片 -->
    <view class="card">
      <block wx:if="{{canIUseNicknameComp && !hasUserInfo}}">
        <!-- 头像选择 -->
        <view class="avatar-section">
          <button class="avatar-wrapper" open-type="chooseAvatar" bind:chooseavatar="onChooseAvatar">
            <image class="avatar-img" src="{{userInfo.avatarUrl || 'https://mmbiz.qpic.cn/mmbiz/icTdbqWNOwNRna42FI242Lcia07jQodd2FJGIYQfG0LAJGFxM4FbnQP6yfMxBgJ0F3YRqJCJ1aPAK2dQagdusBZg/0'}}" mode="aspectFill"></image>
          </button>
          <text class="tip-text">点击上方图标设置头像</text>
        </view>

        <!-- 昵称输入 -->
        <view class="input-group">
          <text class="input-label">昵称</text>
          <input type="nickname" class="nickname-input" placeholder="请输入您的昵称" placeholder-class="placeholder-style" bind:change="onInputChange" />
        </view>

        <!-- 登录按钮 -->
        <button 
          class="btn-primary"
          bindtap="handleLogin" 
          hover-class="btn-primary-hover"
        >
          进入系统
        </button>
      </block>

      <block wx:else>
        <view class="logged-in-view">
          <image class="userinfo-avatar-large" src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
          <text class="welcome-text">欢迎回来，{{userInfo.nickName}}</text>
          <button class="btn-primary" bindtap="loginToServer" hover-class="btn-primary-hover">立即进入</button>
        </view>
      </block>
    </view>
  </view>

  <!-- 页面底部 -->
  <view class="footer">
    <text>© 2026 Intelligent Homework System</text>
  </view>
</view>