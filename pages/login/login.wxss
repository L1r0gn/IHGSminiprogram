/** login.wxss **/
page {
  background-color: #f5f7fa;
  height: 100%;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC',
               'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
}

/* 页面容器 */
.page-container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.content-wrapper {
  flex: 1;
  width: 100%;
  padding: 60rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 页面头部 */
.page-header {
  margin-bottom: 60rpx;
  padding: 20rpx 0;
  animation: fadeIn 0.6s ease-out;
  text-align: center;
}

.app-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #1a1a1a;
  display: block;
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
}

.app-subtitle {
  font-size: 28rpx;
  color: #64748b;
  display: block;
  letter-spacing: 6rpx;
}

/* 卡片样式 */
.card {
  width: 100%;
  max-width: 600rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 50rpx 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  display: flex;
  flex-direction: column;
  align-items: center;
  animation: fadeInUp 0.8s ease-out;
}

.card:active {
  transform: translateY(-4rpx);
  box-shadow: 0 16rpx 40rpx rgba(0, 0, 0, 0.12);
}

/* 头像区域 */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 50rpx;
  animation: fadeInUp 0.8s ease-out 0.2s both;
}

.avatar-wrapper {
  padding: 0;
  width: 140rpx !important;
  height: 140rpx !important;
  border-radius: 50%;
  /* background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); */
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 16rpx;
  position: relative;
  overflow: hidden;
}

.avatar-wrapper::after {
  content: '';
  position: absolute;
  width: 136rpx;
  height: 136rpx;
  border-radius: 50%;
  background: #fff;
  top: 2rpx;
  left: 2rpx;
}

.avatar-img {
  width: 136rpx;
  height: 136rpx;
  border-radius: 50%;
  position: relative;
  z-index: 1;
}

.tip-text {
  font-size: 26rpx;
  color: #94a3b8;
}

/* 输入框组 */
.input-group {
  width: 100%;
  display: flex;
  align-items: center;
  background: #f5f7fa;
  border-radius: 16rpx;
  padding: 24rpx 30rpx;
  margin-bottom: 60rpx;
  box-sizing: border-box;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
  animation: fadeInUp 0.8s ease-out 0.3s both;
}

.input-group:focus-within {
  background: #fff;
  border-color: #667eea;
  box-shadow: 0 0 0 4rpx rgba(102, 126, 234, 0.1);
}

.input-label {
  font-size: 28rpx;
  color: #1e293b;
  font-weight: 600;
  margin-right: 30rpx;
  min-width: 60rpx;
}

.nickname-input {
  flex: 1;
  font-size: 28rpx;
  color: #1a1a1a;
  height: 100%;
}

.placeholder-style {
  color: #94a3b8;
}

/* 主按钮 */
.btn-primary {
  width: 100% !important;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 20rpx rgba(102, 126, 234, 0.3);
  transition: all 0.3s ease;
  margin: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  animation: fadeInUp 0.8s ease-out 0.4s both;
}

.btn-primary:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.4);
}

/* 已登录状态 */
.logged-in-view {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  animation: fadeInUp 0.8s ease-out 0.2s both;
}

.userinfo-avatar-large {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  margin-bottom: 30rpx;
  border: 6rpx solid #f5f7fa;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.2);
  animation: breathe 2s ease-in-out infinite;
}

.welcome-text {
  font-size: 32rpx;
  color: #1a1a1a;
  font-weight: 600;
  margin-bottom: 60rpx;
}

/* 底部 */
.footer {
  padding: 40rpx;
  text-align: center;
}

.footer text {
  font-size: 24rpx;
  color: #94a3b8;
}

/* 动画 */
@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes breathe {
  0%, 100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.02);
  }
}
